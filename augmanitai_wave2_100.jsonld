    {
      "@type": "DefinedTerm",
      "@id": "https://augmanitai.com/terms/AUG-0098",
      "name": "Thinking Leverage",
      "description": "Beobachtbares Verhaeltnis zwischen kognitivem Aufwand und KI-gestuetztem Ergebnis. Hebel-Metapher fuer ein Interaktionsmuster.",
      "inDefinedTermSet": "https://augmanitai.com/terms/periodic/",
      "termCode": "AUG-0098",
      "alternateName": "THL",
      "inLanguage": "de",
      "about": "KG",
      "operationalDefinition": "Thinking Leverage is observed when AI-augmentation enables a participant to complete cognitive tasks of higher complexity (operationalised via Bloom's taxonomy level) than their solo baseline, measured by complexity-level-achieved across matched task-pairs.",
      "measurementSchema": "Repeated-measures ANOVA with sphericity correction (Greenhouse-Geisser) applied to Bloom-level achieved across three conditions: solo, AI-assisted minimal, AI-assisted full. Leverage = F-value for AI-condition main effect; post-hoc pairwise comparisons via Tukey HSD.",
      "exampleData": "{\"participants_n\": 36, \"tasks_per_condition\": 8, \"bloom_mean_solo\": 3.2, \"bloom_mean_minimal_ai\": 4.1, \"bloom_mean_full_ai\": 4.9, \"f_value\": 28.4, \"gg_epsilon\": 0.87, \"p_value\": 1e-06}",
      "broader": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-cognition-thought",
      "inScheme": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-cognition-thought",
      "mainEntityOfPage": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0098.html",
      "citation": "https://zenodo.org/communities/augmanitai",
      "position": 4,
      "relatedTerm": [
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0004.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0054.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0002.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0089.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0016.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0205.html"
      ],
      "inclusionCriteria": "Matched task-triplets across all three conditions within-participant.",
      "exclusionCriteria": "Tasks where AI-augmentation effectively performs the task rather than assisting."
    },
    {
      "@type": "DefinedTerm",
      "@id": "https://augmanitai.com/terms/AUG-0156",
      "name": "Articulation Unlock",
      "description": "Beobachtbarer Moment, in dem KI-Unterstuetzung bei der Formulierung eigener Gedanken hilft. Ein Artikulationsphaenomen.",
      "inDefinedTermSet": "https://augmanitai.com/terms/periodic/",
      "termCode": "AUG-0156",
      "alternateName": "ART",
      "inLanguage": "de",
      "about": "KM",
      "operationalDefinition": "Articulation Unlock is recorded when a participant who initially reports inability to express an idea ('I can't put it into words') produces a coherent verbal formulation of that idea within five turns of AI-mediated dialogue, verified by self-report and by external rater rating of formulation-coherence.",
      "measurementSchema": "Pre-post articulation-rating: participant rates expression-difficulty (0-10) at baseline and after AI dialogue; external rater scores formulation-coherence (1-5) on the post-dialogue statement. Unlock = baseline-difficulty drop greater than 4 points AND coherence-rating greater than or equal to 4.",
      "exampleData": "{\"session_id\": \"S058\", \"participant\": \"P019\", \"baseline_difficulty\": 8, \"post_difficulty\": 3, \"difficulty_drop\": 5, \"coherence_rating\": 4, \"turns_to_unlock\": 4}",
      "broader": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-communication-language",
      "inScheme": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-communication-language",
      "mainEntityOfPage": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0156.html",
      "citation": "https://zenodo.org/communities/augmanitai",
      "position": 1,
      "relatedTerm": [
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0403.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0513.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0478.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0188.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0137.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0283.html"
      ],
      "inclusionCriteria": "Difficulty drop greater than 4 points and coherence rating at or above 4 within 5 turns.",
      "exclusionCriteria": "Cases where the participant already had partial formulation at baseline (difficulty score below 6)."
    },
    {
      "@type": "DefinedTerm",
      "@id": "https://augmanitai.com/terms/AUG-0403",
      "name": "The Translation Relief",
      "description": "Beobachtbare emotionale Reaktion wenn KI sprachliche Barrieren abbaut und Uebersetzungsarbeit erleichtert.",
      "inDefinedTermSet": "https://augmanitai.com/terms/periodic/",
      "termCode": "AUG-0403",
      "alternateName": "TRR",
      "inLanguage": "de",
      "about": "KM",
      "operationalDefinition": "Translation Relief is recorded when a participant who reports prior translation-effort or anxiety in a cross-language exchange experiences a measurable cognitive-load reduction after AI translation-assistance, indicated by both self-report and a secondary-task performance recovery.",
      "measurementSchema": "Dual-task paradigm: participant performs cross-language exchange with concurrent secondary task (n-back); subjective NASA-TLX before and after AI-translation introduction; secondary-task accuracy compared across conditions. Relief = TLX drop greater than 15 points and secondary-task accuracy gain greater than 10%.",
      "exampleData": "{\"participant_id\": \"P025\", \"tlx_pre\": 72, \"tlx_post\": 48, \"tlx_drop\": 24, \"n_back_acc_pre\": 0.62, \"n_back_acc_post\": 0.79, \"language_pair\": \"DE-EN\"}",
      "broader": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-communication-language",
      "inScheme": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-communication-language",
      "mainEntityOfPage": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0403.html",
      "citation": "https://zenodo.org/communities/augmanitai",
      "position": 2,
      "relatedTerm": [
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0156.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0513.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0478.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0501.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0267.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0137.html"
      ],
      "inclusionCriteria": "TLX drop greater than 15 points and secondary-task accuracy gain greater than 10%.",
      "exclusionCriteria": "Participants with bilingual fluency in the target language pair (TLX baseline below 30)."
    },
    {
      "@type": "DefinedTerm",
      "@id": "https://augmanitai.com/terms/AUG-0513",
      "name": "The Language Buddy",
      "description": "KI als Sprachwerkzeug mit wiederholbarer Korrektur- und Erklaerfunktion. Beobachtbar als Ergaenzung zum Sprachunterricht.",
      "inDefinedTermSet": "https://augmanitai.com/terms/periodic/",
      "termCode": "AUG-0513",
      "alternateName": "LBD",
      "inLanguage": "de",
      "about": "KM",
      "operationalDefinition": "Language Buddy use is observed when a participant uses an AI system over a sustained period (at least 4 weeks, at least 3 sessions per week) for low-stakes second-language practice and reports both increased speaking-confidence and measurable vocabulary or fluency gains.",
      "measurementSchema": "Longitudinal mixed-methods: weekly session-frequency log, pre-post vocabulary test (50-item), and pre-post 2-minute spoken sample scored on CEFR descriptors. Confidence tracked via weekly 7-point Likert. Primary outcome: vocabulary delta + CEFR-band shift.",
      "exampleData": "{\"participant_id\": \"P042\", \"weeks_logged\": 6, \"sessions_total\": 23, \"vocab_pre\": 28, \"vocab_post\": 41, \"cefr_pre\": \"A2\", \"cefr_post\": \"B1\", \"confidence_delta\": 2.1}",
      "broader": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-communication-language",
      "inScheme": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-communication-language",
      "mainEntityOfPage": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0513.html",
      "citation": "https://zenodo.org/communities/augmanitai",
      "position": 2,
      "relatedTerm": [
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0156.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0403.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0478.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0267.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0501.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0188.html"
      ],
      "inclusionCriteria": "Sustained use (at least 4 weeks, at least 12 sessions) with both confidence and proficiency measures available.",
      "exclusionCriteria": "Exam-prep crash-use or single-session interventions."
    },
    {
      "@type": "DefinedTerm",
      "@id": "https://augmanitai.com/terms/AUG-0478",
      "name": "The Clarity Catalyst",
      "description": "Beobachtbares Phaenomen: der Zwang zur expliziten Formulierung in KI-Interaktion veraendert den Denkprozess.",
      "inDefinedTermSet": "https://augmanitai.com/terms/periodic/",
      "termCode": "AUG-0478",
      "alternateName": "CLC",
      "inLanguage": "de",
      "about": "KM",
      "operationalDefinition": "Clarity Catalyst is observed when an AI interaction produces measurable improvement in the readability and structure of a participant's written articulation of a complex idea, comparing pre-interaction and post-interaction drafts of the same topic.",
      "measurementSchema": "Pre-post draft comparison using Flesch-Kincaid Grade Level and a structure-rubric (thesis, transitions, conclusion - 5-point each). Clarity-gain = pre-post change in composite score; statistical test via Wilcoxon signed-rank across participants.",
      "exampleData": "{\"participant_id\": \"P079\", \"topic\": \"policy-brief\", \"fk_pre\": 14.2, \"fk_post\": 11.6, \"structure_pre\": 2.4, \"structure_post\": 4.2, \"clarity_gain\": 4.4}",
      "broader": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-communication-language",
      "inScheme": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-communication-language",
      "mainEntityOfPage": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0478.html",
      "citation": "https://zenodo.org/communities/augmanitai",
      "position": 3,
      "relatedTerm": [
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0156.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0403.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0513.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0283.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0267.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0501.html"
      ],
      "inclusionCriteria": "Both drafts on same topic with composite clarity-gain greater than 1.5 and Wilcoxon p less than 0.05 at cohort level.",
      "exclusionCriteria": "Cases where the AI rewrote the draft directly rather than coaching the participant to revise."
    },

    {
      "@type": "DefinedTerm",
      "@id": "https://augmanitai.com/terms/AUG-0566",
      "name": "Ongoing Partnership",
      "description": "Die Entwicklung einer kontinuierlichen, produktiven Arbeitsbeziehung zwischen Mensch und KI-System.",
      "inDefinedTermSet": "https://augmanitai.com/terms/periodic/",
      "termCode": "AUG-0566",
      "alternateName": "OGP",
      "inLanguage": "de",
      "about": "RL",
      "operationalDefinition": "Ongoing Partnership is observed when a participant maintains a sustained AI-collaboration on a single project across at least 12 weeks, with documented continuity of context (named project, recurring references, evolving artifacts) and a stable working-cadence at least once weekly.",
      "measurementSchema": "Project-log audit: weeks-active, session-cadence (mean inter-session days), artifact-evolution count (versions / drafts referenced), and continuity-index = proportion of sessions referencing prior session content. Partnership-strength = weeks-active x continuity-index.",
      "exampleData": "{\"project_id\": \"PR003\", \"participant\": \"P005\", \"weeks_active\": 18, \"sessions_total\": 24, \"mean_intersession_days\": 5.2, \"artifact_versions\": 9, \"continuity_index\": 0.87, \"partnership_strength\": 15.7}",
      "broader": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-relation-trust",
      "inScheme": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-relation-trust",
      "mainEntityOfPage": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0566.html",
      "citation": "https://zenodo.org/communities/augmanitai",
      "position": 2,
      "relatedTerm": [
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0539.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0170.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0177.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0981.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0161.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0080.html"
      ],
      "inclusionCriteria": "Twelve weeks or more of activity with continuity-index above 0.7 and at least weekly cadence.",
      "exclusionCriteria": "General-purpose assistant use without an identifiable single project."
    },
    {
      "@type": "DefinedTerm",
      "@id": "https://augmanitai.com/terms/AUG-0539",
      "name": "The Companion Shift",
      "description": "Der beobachtbare Wandel in der Wahrnehmung der KI: vom statischen Werkzeug zum flexiblen Arbeitsinstrument.",
      "inDefinedTermSet": "https://augmanitai.com/terms/periodic/",
      "termCode": "AUG-0539",
      "alternateName": "CPS",
      "inLanguage": "de",
      "about": "RL",
      "operationalDefinition": "A Companion Shift is recorded when a participant's framing of an AI system transitions from task-tool to ongoing companion across a longitudinal window, evidenced by changes in language (pronoun use, naming, conversational openings) and by self-reported relational orientation on a validated scale.",
      "measurementSchema": "Longitudinal linguistic-feature tracking (pronoun frequency, address-form use, opening-greeting types) across at least 8 weeks of session-logs, paired with monthly Inclusion-of-Other-in-Self (IOS) scale (1-7). Shift detected when IOS rises by at least 2 points and pronoun-personalisation more than doubles.",
      "exampleData": "{\"participant_id\": \"P033\", \"weeks_observed\": 10, \"ios_week1\": 2, \"ios_week10\": 5, \"personal_pronoun_rate_w1\": 0.08, \"personal_pronoun_rate_w10\": 0.22, \"named_assistant\": true}",
      "broader": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-relation-trust",
      "inScheme": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-relation-trust",
      "mainEntityOfPage": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0539.html",
      "citation": "https://zenodo.org/communities/augmanitai",
      "position": 2,
      "relatedTerm": [
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0566.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0170.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0177.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0981.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0577.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0201.html"
      ],
      "inclusionCriteria": "IOS increase at least 2 points plus more than doubled personalisation-rate over the observation window.",
      "exclusionCriteria": "Cases where the participant explicitly role-plays a companion frame from session one."
    },
    {
      "@type": "DefinedTerm",
      "@id": "https://augmanitai.com/terms/AUG-0170",
      "name": "Witness Effect",
      "description": "KI als aufmerksames Gegenueber: ein System, dem man Gedanken externalisieren kann. Deskriptive Beobachtung.",
      "inDefinedTermSet": "https://augmanitai.com/terms/periodic/",
      "termCode": "AUG-0170",
      "alternateName": "WIT",
      "inLanguage": "de",
      "about": "RL",
      "operationalDefinition": "The Witness Effect is recorded when a participant reports increased clarity, validation, or motivation after articulating a thought to an AI system without receiving substantive AI response (acknowledgment-only or minimal-feedback condition). Effect is measured against a no-AI journaling control.",
      "measurementSchema": "Randomised within-subject design with three conditions: (A) AI acknowledgment-only, (B) AI substantive feedback, (C) silent journaling. Outcomes: clarity-rating (10-point), motivation-rating (10-point), and follow-up behavioural intent at 24 hours. Witness Effect = A greater than C on at least one outcome.",
      "exampleData": "{\"participant_id\": \"P020\", \"condition_A_clarity\": 7.2, \"condition_B_clarity\": 7.8, \"condition_C_clarity\": 5.4, \"A_minus_C_clarity\": 1.8, \"intent_followthrough_A\": true}",
      "broader": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-relation-trust",
      "inScheme": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-relation-trust",
      "mainEntityOfPage": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0170.html",
      "citation": "https://zenodo.org/communities/augmanitai",
      "position": 2,
      "relatedTerm": [
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0566.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0539.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0177.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0201.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0080.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0161.html"
      ],
      "inclusionCriteria": "Condition A score significantly higher than condition C on at least one outcome (paired-test p less than 0.05).",
      "exclusionCriteria": "Sessions where condition A contained substantive AI feedback (protocol breach)."
    },
    {
      "@type": "DefinedTerm",
      "@id": "https://augmanitai.com/terms/AUG-0177",
      "name": "The Trust Setting",
      "description": "Die individuelle Kalibrierung des Vertrauensniveaus gegenueber einem KI-System. Bewusst gesteuert.",
      "inDefinedTermSet": "https://augmanitai.com/terms/periodic/",
      "termCode": "AUG-0177",
      "alternateName": "TRS",
      "inLanguage": "de",
      "about": "RL",
      "operationalDefinition": "A Trust Setting is observed when a participant adjusts their disclosure-threshold and verification-effort with an AI system over time based on accumulated experience, evidenced by changes in private-information-disclosed and verification-events-per-claim across a longitudinal window.",
      "measurementSchema": "Hedonic and eudaimonic well-being scale (8-item) administered monthly alongside disclosure-log analysis (sensitive-token frequency) and verification-event count. Trust-setting trajectory fitted with linear mixed-effects model with random intercepts per participant.",
      "exampleData": "{\"participant_id\": \"P091\", \"weeks_observed\": 12, \"disclosure_tokens_w1\": 14, \"disclosure_tokens_w12\": 38, \"verification_per_claim_w1\": 0.62, \"verification_per_claim_w12\": 0.21, \"well_being_delta\": 1.4}",
      "broader": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-relation-trust",
      "inScheme": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-relation-trust",
      "mainEntityOfPage": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0177.html",
      "citation": "https://zenodo.org/communities/augmanitai",
      "position": 2,
      "relatedTerm": [
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0566.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0539.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0170.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0981.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0080.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0197.html"
      ],
      "inclusionCriteria": "At least 12 weeks observation with monotonic disclosure-trend and verification-trend in opposite directions.",
      "exclusionCriteria": "Trajectories driven by external trust-shock events (data-breach news, platform-policy change) within the window."
    },

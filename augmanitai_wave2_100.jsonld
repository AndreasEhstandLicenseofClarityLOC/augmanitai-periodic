    {
      "@type": "DefinedTerm",
      "@id": "https://augmanitai.com/terms/AUG-0921",
      "name": "Swarm Access",
      "description": "Beobachtbarer Zugang zu breiterer KI-Kapazitaet durch vernetzte Agentensysteme. Skalierung unter menschlicher Aufsicht.",
      "inDefinedTermSet": "https://augmanitai.com/terms/periodic/",
      "termCode": "AUG-0921",
      "alternateName": "SWA",
      "inLanguage": "de",
      "about": "AG",
      "operationalDefinition": "Swarm Access is observed when a participant simultaneously delegates a single task to multiple parallel AI agents and orchestrates their combined outputs, characterised by parallel-dispatch logs and an integration-step that merges divergent agent outputs.",
      "measurementSchema": "Job Crafting Scale (orchestration sub-component) administered alongside parallel-agent-dispatch logs. Swarm-Access index = mean parallel-agents-per-task x integration-step explicitness rating.",
      "exampleData": "{\"participant\": \"P067\", \"tasks_with_swarm\": 14, \"mean_parallel_agents\": 4.2, \"integration_explicitness_mean\": 3.8, \"swarm_access_index\": 15.96, \"job_crafting_orchestration\": 6.1}",
      "broader": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-agentic-ai",
      "inScheme": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-agentic-ai",
      "mainEntityOfPage": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0921.html",
      "citation": "https://zenodo.org/communities/augmanitai",
      "position": 4,
      "relatedTerm": [
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0859.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0860.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0914.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0915.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0868.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0888.html"
      ],
      "inclusionCriteria": "Verifiable parallel-dispatch logs across >= 5 tasks AND integration-step coded.",
      "exclusionCriteria": "Sequential agent-use mislabelled as parallel."
    },
    {

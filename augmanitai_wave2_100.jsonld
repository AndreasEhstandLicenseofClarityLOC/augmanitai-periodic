      "relatedTerm": [
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0046.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0025.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0127.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0081.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0061.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0128.html"
      ]
    },
    {
      "@type": "DefinedTerm",
      "@id": "https://augmanitai.com/terms/AUG-0245",
      "name": "The Seen Feeling",
      "description": "Das Gefuehl, praezise verstanden zu werden. Ein beobachtbares Interaktionsphaenomen, kein Beziehungsersatz.",
      "inDefinedTermSet": "https://augmanitai.com/terms/periodic/",
      "termCode": "AUG-0245",
      "alternateName": "TSF",
      "inLanguage": "de",
      "about": "EM",
      "operationalDefinition": "Operational scope: an instance of 'The Seen Feeling' is counted when the observable pattern described above (Das Gefuehl, praezise verstanden zu werden. Ein beobachtbares Interaktionsphaeno...) occurs at least once within a defined interaction segment of N turns (typically N=10), as coded by trained raters.",
      "measurementSchema": "Sensor-coupling latency (ms) between human action and AI response in physical/multimodal channels.",
      "exampleData": "{\"session_id\": \"S001\", \"sensor_coupling_latency_ms\": 47, \"n_actions\": 20}",
      "broader": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-emotion-affect",
      "inScheme": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-emotion-affect",
      "mainEntityOfPage": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0245.html",
      "citation": "https://zenodo.org/communities/augmanitai",
      "position": 1,
      "relatedTerm": [
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0046.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0025.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0127.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0301.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0529.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0061.html"
      ]
    },
    {
      "@type": "DefinedTerm",
      "@id": "https://augmanitai.com/terms/AUG-0128",
      "name": "The Gratitude Response",
      "description": "Spontane Dankbarkeit gegenueber einem KI-System nach einer hilfreichen Interaktion. Ein natuerlicher menschlicher Impuls.",
      "inDefinedTermSet": "https://augmanitai.com/terms/periodic/",
      "termCode": "AUG-0128",
      "alternateName": "GRR",
      "inLanguage": "de",
      "about": "EM",
      "operationalDefinition": "The Gratitude Response is observed when an AI-mediated experience prompts a participant to express gratitude toward another person (human, not the AI), measured by gratitude-expressions emitted within 48 hours of the AI-session.",
      "measurementSchema": "Self-Determination Theory (SDT) relatedness-subscale administered alongside gratitude-expression log (daily diary). Gratitude Response rate = expressions per AI-session moderated by relatedness-baseline score.",
      "exampleData": "{\"participant\": \"P057\", \"ai_sessions_window_days\": 7, \"ai_sessions_n\": 9, \"gratitude_expressions_to_others\": 14, \"sdt_relatedness_score\": 5.8, \"response_rate_per_session\": 1.56}",
      "broader": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-emotion-affect",
      "inScheme": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-emotion-affect",
      "mainEntityOfPage": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0128.html",
      "citation": "https://zenodo.org/communities/augmanitai",
      "position": 2,
      "relatedTerm": [
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0046.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0025.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0127.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0301.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0529.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0061.html"
      ],
      "inclusionCriteria": "Daily gratitude-diary completed AND SDT relatedness-subscale within 14 days.",
      "exclusionCriteria": "Sessions immediately preceding routine gratitude-events (e.g., birthdays)."
    },
    {
      "@type": "DefinedTerm",
      "@id": "https://augmanitai.com/terms/AUG-0529",
      "name": "The Closeness Bridge",
      "description": "Beobachtbares Phaenomen: das Erlebnis, Gedanken strukturiert externalisieren zu koennen, erzeugt ein Gefuehl produktiver Verbundenheit.",
      "inDefinedTermSet": "https://augmanitai.com/terms/periodic/",
      "termCode": "AUG-0529",
      "alternateName": "CLB",
      "inLanguage": "de",
      "about": "EM",
      "operationalDefinition": "The Closeness Bridge is observed when AI-mediated dialogue prompts contribute to a measurable increase in perceived interpersonal closeness between two human participants who later interact, even when the AI is not present in the dyadic interaction.",
      "measurementSchema": "Implicit Association Test (IAT) reaction-time paradigm with target-other concept and closeness-attribute pairs, administered pre- and post-AI-bridge session. Closeness shift = D-score change pre to post; larger negative D = stronger implicit closeness.",
      "exampleData": "{\"dyad_id\": \"D012\", \"participants\": [\"P019\", \"P020\"], \"iat_d_score_pre\": 0.34, \"iat_d_score_post\": -0.12, \"shift_magnitude\": 0.46, \"explicit_closeness_change\": 1.8}",
      "broader": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-emotion-affect",
      "inScheme": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-emotion-affect",
      "mainEntityOfPage": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0529.html",
      "citation": "https://zenodo.org/communities/augmanitai",
      "position": 2,
      "relatedTerm": [
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0046.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0025.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0127.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0061.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0168.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0128.html"
      ],
      "inclusionCriteria": "Dyadic pair completing IAT both pre and post bridge-session.",
      "exclusionCriteria": "Dyads with established closeness (pre-IAT D-score below -0.5)."
    },
    {
      "@type": "DefinedTerm",
      "@id": "https://augmanitai.com/terms/AUG-0081",
      "name": "Post-Authorial Pride",
      "description": "Stolz auf ein KI-co-erstelltes Ergebnis. Die Freude am gemeinsam Geschaffenen.",
      "inDefinedTermSet": "https://augmanitai.com/terms/periodic/",
      "termCode": "AUG-0081",
      "alternateName": "PAP",
      "inLanguage": "de",
      "about": "EM",
      "operationalDefinition": "Operational scope: an instance of 'Post-Authorial Pride' is counted when the observable pattern described above (Stolz auf ein KI-co-erstelltes Ergebnis. Die Freude am gemeinsam Geschaffenen....) occurs at least once within a defined interaction segment of N turns (typically N=10), as coded by trained raters.",
      "measurementSchema": "Sensor-coupling latency (ms) between human action and AI response in physical/multimodal channels.",
      "exampleData": "{\"session_id\": \"S001\", \"sensor_coupling_latency_ms\": 47, \"n_actions\": 20}",
      "broader": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-emotion-affect",
      "inScheme": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-emotion-affect",
      "mainEntityOfPage": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0081.html",

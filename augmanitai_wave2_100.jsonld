        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0915.html"
      ]
    },
    {
      "@type": "DefinedTerm",
      "@id": "https://augmanitai.com/terms/AUG-0868",
      "name": "The Rollback Option",
      "description": "Die Moeglichkeit, jede KI-Aktion rueckgaengig zu machen. Kontrollarchitektur als Sicherheitsnetz.",

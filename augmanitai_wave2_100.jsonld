    {
      "@type": "DefinedTerm",
      "@id": "https://augmanitai.com/terms/AUG-0119",
      "name": "Level Playing Field",
      "description": "Beobachtbare Tendenz zur breiteren Verfuegbarkeit von Wissen und Werkzeugen durch KI-Technologien.",
      "inDefinedTermSet": "https://augmanitai.com/terms/periodic/",
      "termCode": "AUG-0119",
      "alternateName": "LPF",
      "inLanguage": "de",
      "about": "GS",
      "operationalDefinition": "A Level Playing Field is observed when access-to-AI gaps between baseline-high-resource and baseline-low-resource participants narrow on a task-outcome metric over a defined intervention window. The narrowing must be larger than would be predicted by general practice-effects alone.",
      "measurementSchema": "Difference-in-differences regression with high-resource and low-resource cohorts pre and post AI-access introduction. Outcome variable = task-performance score; primary estimand = DiD coefficient with 95% CI. Cohen's f-squared for effect-size of the interaction term.",
      "exampleData": "{\"cohort_high_pre\": 78.2, \"cohort_low_pre\": 54.1, \"cohort_high_post\": 81.5, \"cohort_low_post\": 73.6, \"did_coefficient\": 16.2, \"cohen_f_squared\": 0.28}",
      "broader": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-society-culture",
      "inScheme": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-society-culture",
      "mainEntityOfPage": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0119.html",
      "citation": "https://zenodo.org/communities/augmanitai",
      "position": 5,
      "relatedTerm": [
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0010.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0198.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0093.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0099.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0834.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0847.html"
      ],
      "inclusionCriteria": "Both cohorts measured pre and post with statistically significant DiD coefficient (p less than 0.05).",
      "exclusionCriteria": "Designs without parallel-trends assumption check or with cohort-attrition above 20%."
    },
    {
      "@type": "DefinedTerm",
      "@id": "https://augmanitai.com/terms/AUG-0010",
      "name": "Bridge Species",
      "description": "Menschen die beide Welten kennen: vor und nach KI. Lebende Bruecken mit einzigartiger Vergleichsperspektive.",
      "inDefinedTermSet": "https://augmanitai.com/terms/periodic/",
      "termCode": "AUG-0010",
      "alternateName": "BRS",
      "inLanguage": "de",
      "about": "GS",
      "operationalDefinition": "Bridge Species behaviour is observed when a participant acts as translator between AI-fluent and AI-naive communities, evidenced by mediated explanations and conversion of AI-output into community-appropriate language in observed exchanges across both populations.",
      "measurementSchema": "Social-network mediation analysis: participant logged as edge between AI-fluent cluster A and AI-naive cluster B over 30 days. Mediation strength = betweenness-centrality score; translation-quality coded on a 5-point rubric per observed exchange.",
      "exampleData": "{\"participant_id\": \"P062\", \"network_window_days\": 30, \"cluster_A_contacts\": 14, \"cluster_B_contacts\": 22, \"betweenness_centrality\": 0.34, \"translation_quality_mean\": 4.1}",
      "broader": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-society-culture",
      "inScheme": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-society-culture",
      "mainEntityOfPage": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0010.html",
      "citation": "https://zenodo.org/communities/augmanitai",
      "position": 5,
      "relatedTerm": [
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0119.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0198.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0093.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0834.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0808.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0730.html"
      ],
      "inclusionCriteria": "Documented exchanges with members of both clusters and betweenness-centrality above 0.2.",
      "exclusionCriteria": "Participants whose contacts fall entirely within one cluster or who do not produce translation-explanations."
    },
    {
      "@type": "DefinedTerm",
      "@id": "https://augmanitai.com/terms/AUG-0198",
      "name": "The New Literacy",
      "description": "Beobachtbarer gesellschaftlicher Trend: KI-Kompetenz als sich entwickelnde Kulturtechnik, vergleichbar mit historischen Bildungsumbruechen.",
      "inDefinedTermSet": "https://augmanitai.com/terms/periodic/",
      "termCode": "AUG-0198",
      "alternateName": "NLI",
      "inLanguage": "de",
      "about": "GS",
      "operationalDefinition": "The New Literacy is observed when a participant demonstrates fluency in AI-mediated information practices (prompt-formulation, source-triangulation, output-curation) measured on a competency rubric, with performance significantly above a digital-literacy-control baseline on standardised tasks.",
      "measurementSchema": "Performance-based assessment on n=12 standardised AI-literacy tasks scored by Cohen's d effect-size against a digital-literacy-only control group. Sub-scales: prompt-craft, output-evaluation, source-verification, curation. Reported with 95% CI per sub-scale.",
      "exampleData": "{\"participant_id\": \"P051\", \"tasks_completed\": 12, \"ai_literacy_score\": 78.4, \"control_mean\": 52.1, \"cohen_d\": 1.42, \"weakest_subscale\": \"source-verification\"}",
      "broader": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-society-culture",
      "inScheme": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-society-culture",
      "mainEntityOfPage": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0198.html",
      "citation": "https://zenodo.org/communities/augmanitai",
      "position": 5,
      "relatedTerm": [
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0119.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0010.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0093.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0808.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0730.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0847.html"
      ],
      "inclusionCriteria": "All 12 tasks completed with effect-size d greater than 0.8 against control on composite score.",
      "exclusionCriteria": "Participants with prior formal AI training (course completion certificate) introducing selection bias."
    },
    {
      "@type": "DefinedTerm",
      "@id": "https://augmanitai.com/terms/AUG-0093",
      "name": "Zero-Marginal Cost",
      "description": "Beobachtbare Tendenz sinkender Grenzkosten kreativer Produktion durch KI-Unterstuetzung.",
      "inDefinedTermSet": "https://augmanitai.com/terms/periodic/",
      "termCode": "AUG-0093",
      "alternateName": "ZMC",
      "inLanguage": "de",
      "about": "GS",
      "operationalDefinition": "Zero-Marginal Cost behaviour is observed when a participant treats additional AI-mediated trials, drafts, or queries as effectively cost-free in their decision-making, evidenced by trial-volume distributions and verbal markers indicating no per-trial cost-calculation occurs.",
      "measurementSchema": "Trial-volume distribution analysis: log-scale histogram of queries-per-task with comparison to pre-AI baseline. BIS/BAS (Behavioral Inhibition / Behavioral Activation) scales administered to assess approach-motivation correlate with high trial-volume.",
      "exampleData": "{\"participant_id\": \"P097\", \"task_id\": \"T067\", \"queries_n\": 47, \"baseline_queries\": 4, \"log_ratio\": 2.5, \"bas_drive_score\": 14, \"cost_verbalisations\": 0}",
      "broader": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-society-culture",
      "inScheme": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-society-culture",
      "mainEntityOfPage": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0093.html",
      "citation": "https://zenodo.org/communities/augmanitai",
      "position": 5,
      "relatedTerm": [
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0119.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0010.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0198.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0730.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0847.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0099.html"
      ],
      "inclusionCriteria": "Trial-volume above 10x baseline with zero per-trial cost-verbalisations in transcript.",
      "exclusionCriteria": "Tasks with explicit AI-usage quotas that constrain trial-volume artificially."
    },
    {
      "@type": "DefinedTerm",
      "@id": "https://augmanitai.com/terms/AUG-0099",

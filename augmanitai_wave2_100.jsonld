        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0043.html"
      ],
      "inclusionCriteria": "At least 8 successive pattern-articulations with measurable feature-variance decrease.",
      "exclusionCriteria": "Sessions where the pattern is reframed mid-stream (topic-shift breaking the autocorrelation series)."
    },
    {
      "@type": "DefinedTerm",
      "@id": "https://augmanitai.com/terms/AUG-0205",
      "name": "The Skill Unlock",
      "description": "Beobachtbares Phaenomen: Zugang zu Faehigkeiten, die ohne KI-Unterstuetzung schwerer zugaenglich waeren.",
      "inDefinedTermSet": "https://augmanitai.com/terms/periodic/",
      "termCode": "AUG-0205",
      "alternateName": "SUL",
      "inLanguage": "de",
      "about": "KG",
      "operationalDefinition": "Operational scope: an instance of 'The Skill Unlock' is counted when the observable pattern described above (Beobachtbares Phaenomen: Zugang zu Faehigkeiten, die ohne KI-Unterstuetzung schw...) occurs at least once within a defined interaction segment of N turns (typically N=10), as coded by trained raters.",
      "measurementSchema": "Coding-scheme occurrence count; observer agreement (Cohen's κ).",

    {
      "@type": "DefinedTerm",
      "@id": "https://augmanitai.com/terms/AUG-0001",
      "name": "Augmanitai",
      "description": "Rahmenkonzept fuer bewusste Mensch-KI-Zusammenarbeit. Verbindet Augmentation mit Humanitai. Grundbegriff.",
      "inDefinedTermSet": "https://augmanitai.com/terms/periodic/",
      "termCode": "AUG-0001",
      "alternateName": "AUG",
      "inLanguage": "de",
      "about": "MT",
      "operationalDefinition": "Augmanitai is observed at the corpus-level when sustained human-AI co-production generates terminology, frameworks, and shared artifacts across a defined longitudinal window, evidenced by terminology-uptake metrics and by spaced-repetition retention of co-produced concepts in participant recall tests.",
      "measurementSchema": "Spaced-repetition retention curve: forgetting-curve fitted to recall-test scores at days 1, 7, 30, 90 for co-produced concepts vs solo-produced concepts. Half-life of retention reported per concept-class. Saccade-tracking eye-fixation on terminology in re-encounter task as secondary measure of recognition.",
      "exampleData": "{\"participant_id\": \"P112\", \"concepts_tracked\": 30, \"co_produced_half_life_days\": 64, \"solo_produced_half_life_days\": 28, \"saccade_fixation_ms_co\": 412, \"saccade_fixation_ms_solo\": 287}",
      "broader": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-meta-reflection",
      "inScheme": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-meta-reflection",
      "mainEntityOfPage": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0001.html",
      "citation": "https://zenodo.org/communities/augmanitai",
      "position": 5,
      "relatedTerm": [
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0071.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0075.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0076.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0024.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0078.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0145.html"
      ],
      "inclusionCriteria": "Retention measured at all four time-points with co-produced half-life at least 1.5x solo-produced half-life.",
      "exclusionCriteria": "Concepts re-encountered between testing windows through external exposure (publications, news) that confound retention-attribution."
    },

    {
      "@type": "DefinedTerm",
      "@id": "https://augmanitai.com/terms/AUG-0061",
      "name": "Creator's Question",
      "description": "Die produktive Frage: Was ist mein Beitrag, was ist KI? Foerdert Bewusstsein fuer den eigenen kreativen Anteil.",
      "inDefinedTermSet": "https://augmanitai.com/terms/periodic/",
      "termCode": "AUG-0061",
      "alternateName": "CRQ",
      "inLanguage": "de",
      "about": "EM",
      "operationalDefinition": "Operational scope: an instance of 'Creator's Question' is counted when the observable pattern described above (Die produktive Frage: Was ist mein Beitrag, was ist KI? Foerdert Bewusstsein fue...) occurs at least once within a defined interaction segment of N turns (typically N=10), as coded by trained raters.",
      "measurementSchema": "Sensor-coupling latency (ms) between human action and AI response in physical/multimodal channels.",
      "exampleData": "{\"session_id\": \"S001\", \"sensor_coupling_latency_ms\": 47, \"n_actions\": 20}",
      "broader": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-emotion-affect",

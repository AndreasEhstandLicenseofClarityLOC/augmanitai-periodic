      ]
    },
    {
      "@type": "DefinedTerm",
      "@id": "https://augmanitai.com/terms/AUG-0954",
      "name": "Congruence Review",
      "description": "Regelmaessige Pruefung, ob KI-Systemverhalten noch mit den gesetzten Zielen und Werten uebereinstimmt.",
      "inDefinedTermSet": "https://augmanitai.com/terms/periodic/",
      "termCode": "AUG-0954",
      "alternateName": "CNR",
      "inLanguage": "de",
      "about": "SF",
      "operationalDefinition": "Congruence Review is observed when a participant systematically compares AI-produced outputs against their own stated values or prior positions and documents alignment-deviations on a recurring schedule. Each review event includes the AI-output, the value-anchor, and a deviation-rating.",
      "measurementSchema": "Bipolar congruence rating (-3 to +3) on at least 5 value-dimensions per review event analysed with Q-methodology factor extraction: review-events sorted by value-pattern similarity to identify stable congruence-profiles per participant. Q-sort defining-sort threshold reported per factor.",
      "exampleData": "{\"participant_id\": \"P049\", \"window_days\": 30, \"review_events\": 8, \"value_dimensions\": 5, \"mean_congruence\": 1.4, \"q_factors_extracted\": 2, \"defining_sort_loading\": 0.71, \"deviation_flags\": 3}",
      "broader": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-safety-alignment",
      "inScheme": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-safety-alignment",
      "mainEntityOfPage": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0954.html",
      "citation": "https://zenodo.org/communities/augmanitai",
      "position": 2,
      "relatedTerm": [
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0009.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0632.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0951.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0962.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0958.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0955.html"
      ],
      "inclusionCriteria": "Recurring review-events with at-least 5 value-dimensions rated and Q-sort loading above 0.6 on at least one extracted factor.",
      "exclusionCriteria": "One-off ad-hoc value comparisons without recurring schedule or insufficient sort-events for Q-methodology factor extraction."
    },
    {
      "@type": "DefinedTerm",
      "@id": "https://augmanitai.com/terms/AUG-0009",
      "name": "The Speed Limit",
      "description": "Individuelle Verarbeitungsgeschwindigkeit respektieren. Nicht schneller arbeiten als man pruefen kann.",
      "inDefinedTermSet": "https://augmanitai.com/terms/periodic/",
      "termCode": "AUG-0009",
      "alternateName": "SPL",
      "inLanguage": "de",
      "about": "SF",
      "operationalDefinition": "The Speed Limit is observed when a participant deliberately introduces a delay or throttle on AI-mediated workflows to maintain reflective capacity, evidenced by measurable inter-prompt latency exceeding a user-defined floor and by self-reported reflection-quality remaining above threshold.",
      "measurementSchema": "Inter-prompt latency analysed via Stroop-task reaction-time as a proxy attention-capacity measure at fast vs slow prompt-cadences. Reflection-quality rated on 7-point Likert post-session. Speed-limit effective when latency above 90s correlates with Stroop-RT recovery to baseline.",
      "exampleData": "{\"session_id\": \"S132\", \"participant\": \"P053\", \"mean_inter_prompt_s\": 142, \"stroop_rt_fast_ms\": 712, \"stroop_rt_slow_ms\": 598, \"reflection_likert\": 6, \"limit_effective\": true}",
      "broader": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-safety-alignment",
      "inScheme": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-safety-alignment",
      "mainEntityOfPage": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0009.html",
      "citation": "https://zenodo.org/communities/augmanitai",
      "position": 3,
      "relatedTerm": [
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0954.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0632.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0951.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0962.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0120.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0771.html"
      ],
      "inclusionCriteria": "Inter-prompt latency above participant-set floor and Stroop-RT closer to baseline at slow cadence.",
      "exclusionCriteria": "Latency caused by external interruption rather than participant-imposed throttle."
    },
    {
      "@type": "DefinedTerm",
      "@id": "https://augmanitai.com/terms/AUG-0632",
      "name": "The Offline Moment",
      "description": "Bewusstes Verlassen der KI-Interaktion. Pausen als Teil eines gesunden Arbeitsrhythmus.",
      "inDefinedTermSet": "https://augmanitai.com/terms/periodic/",
      "termCode": "AUG-0632",
      "alternateName": "OFM",
      "inLanguage": "de",
      "about": "SF",
      "operationalDefinition": "An Offline Moment is recorded when a participant disengages from AI-mediated channels for a defined window (minimum 60 minutes) and reports a phenomenologically distinct cognitive or affective state during and after the offline period, captured via experience-sampling.",
      "measurementSchema": "Flow-state experience sampling method: random prompts (4-6 per offline window) measuring concentration, intrinsic-enjoyment, sense-of-control on 9-point scales. Offline-quality index = mean across all sampling points; comparison vs online-baseline via paired t-test.",
      "exampleData": "{\"participant_id\": \"P070\", \"offline_window_min\": 90, \"esm_prompts\": 5, \"concentration_mean\": 7.4, \"enjoyment_mean\": 6.8, \"control_mean\": 7.1, \"online_baseline_diff\": 1.6}",
      "broader": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-safety-alignment",
      "inScheme": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-safety-alignment",
      "mainEntityOfPage": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0632.html",
      "citation": "https://zenodo.org/communities/augmanitai",
      "position": 3,
      "relatedTerm": [
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0954.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0009.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0951.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0958.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0120.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0962.html"
      ],
      "inclusionCriteria": "Offline window above 60 minutes with at least 4 ESM responses and online-baseline available for comparison.",
      "exclusionCriteria": "Disengagement caused by device-failure rather than deliberate offline choice."
    },
    {
      "@type": "DefinedTerm",
      "@id": "https://augmanitai.com/terms/AUG-0951",
      "name": "Value Lock",
      "description": "Bezeichnung fuer die beobachtbare Verankerung menschlicher Werte in autonomen Systemen.",
      "inDefinedTermSet": "https://augmanitai.com/terms/periodic/",
      "termCode": "AUG-0951",
      "alternateName": "VLO",
      "inLanguage": "de",
      "about": "SF",
      "operationalDefinition": "A Value Lock is observed when a participant pre-commits to a value-constraint in an AI-mediated workflow and the constraint persists across subsequent sessions without re-negotiation, verified by constraint-presence in session-headers and absence of constraint-relaxation events.",
      "measurementSchema": "Pupillometry baseline-corrected measurement at constraint-relevant decision-points: pupil-dilation as proxy for cognitive-conflict during constraint-application. Stable lock = low dilation variability across sessions; constraint-relaxation flagged when dilation spikes above 2 SD with verbal relaxation-marker.",
      "exampleData": "{\"participant_id\": \"P100\", \"sessions_observed\": 9, \"constraint_invocations\": 32, \"mean_pupil_diff_mm\": 0.18, \"sd_pupil_diff_mm\": 0.07, \"relaxation_events\": 0}",
      "broader": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-safety-alignment",
      "inScheme": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-safety-alignment",
      "mainEntityOfPage": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0951.html",
      "citation": "https://zenodo.org/communities/augmanitai",
      "position": 3,
      "relatedTerm": [
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0954.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0009.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0632.html",

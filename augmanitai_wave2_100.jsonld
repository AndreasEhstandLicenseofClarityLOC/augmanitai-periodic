    {
      "@type": "DefinedTerm",
      "@id": "https://augmanitai.com/terms/AUG-0859",
      "name": "Agent Handshake",
      "description": "Initialer Kontaktmoment zwischen Mensch und autonomem Agenten. Faehigkeiten und Grenzen werden geklaert.",
      "inDefinedTermSet": "https://augmanitai.com/terms/periodic/",
      "termCode": "AUG-0859",
      "alternateName": "AHS",
      "inLanguage": "de",
      "about": "AG",
      "operationalDefinition": "An Agent Handshake is recorded when two or more AI agents exchange a structured capability-declaration and task-acceptance message before commencing joint work, verified by presence of an explicit handshake-payload in the inter-agent message log.",
      "measurementSchema": "Protocol-conformance check via F1-score (precision-recall) on handshake-payload fields against a reference schema (capability-list, task-id, accept/reject, version). Reported per agent-pair with field-level recall.",
      "exampleData": "{\"session_id\": \"MAS-014\", \"agent_pair\": \"A1-A2\", \"handshakes_n\": 8, \"f1_score\": 0.91, \"precision\": 0.94, \"recall\": 0.88, \"field_recall_min\": \"version-field\"}",
      "broader": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-agentic-ai",
      "inScheme": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-agentic-ai",
      "mainEntityOfPage": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0859.html",
      "citation": "https://zenodo.org/communities/augmanitai",
      "position": 1,
      "relatedTerm": [
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0860.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0914.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0888.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0921.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0915.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0868.html"
      ],
      "inclusionCriteria": "Structured handshake-payload present before joint-task initiation with F1 greater than 0.7.",
      "exclusionCriteria": "Ad-hoc agent-to-agent messaging without schema-conformant handshake."
    },
    {
      "@type": "DefinedTerm",
      "@id": "https://augmanitai.com/terms/AUG-0860",
      "name": "Delegation Depth",
      "description": "Wie viel Entscheidungsfreiheit erhaelt ein Agent? Die bewusste Kalibrierung autonomer Handlungsspielraeume.",
      "inDefinedTermSet": "https://augmanitai.com/terms/periodic/",
      "termCode": "AUG-0860",
      "alternateName": "DLD",
      "inLanguage": "de",
      "about": "AG",
      "operationalDefinition": "Delegation Depth is observed when a participant assigns a multi-step task to an AI agent and the agent executes nested sub-tasks autonomously across at least three levels of decomposition before returning a consolidated output. Depth is counted as the longest sub-task chain.",
      "measurementSchema": "Agent-trace parsing: tree-depth analysis of agent action-graph per delegated task. Reported as maximum-depth, mean-depth across branches, and branching-factor. Success-rate at each depth-level tracked via mixed-effects model time-to-completion.",
      "exampleData": "{\"task_id\": \"T044\", \"participant\": \"P058\", \"max_depth\": 5, \"mean_depth\": 3.2, \"branching_factor\": 2.1, \"completion_time_min\": 14.3, \"success_at_depth_5\": true}",
      "broader": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-agentic-ai",
      "inScheme": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-agentic-ai",
      "mainEntityOfPage": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0860.html",
      "citation": "https://zenodo.org/communities/augmanitai",
      "position": 2,
      "relatedTerm": [
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0859.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0914.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0888.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0921.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0868.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0915.html"
      ],
      "inclusionCriteria": "Documented action-graph with at-least depth 3 and consolidated final output returned to participant.",
      "exclusionCriteria": "Linear single-chain tasks without true branching or human intervention at intermediate steps."
    },
    {
      "@type": "DefinedTerm",
      "@id": "https://augmanitai.com/terms/AUG-0914",
      "name": "Physical Presence",
      "description": "Die Wirkung physischer KI-Praesenz auf die Interaktion. Koerperlichkeit veraendert Dynamik.",
      "inDefinedTermSet": "https://augmanitai.com/terms/periodic/",
      "termCode": "AUG-0914",
      "alternateName": "PHP",
      "inLanguage": "de",
      "about": "AG",
      "operationalDefinition": "Physical Presence is observed when an embodied AI agent (robot, smart-device) shares the participant's physical space and the participant attributes presence-qualities (here-ness, attention, responsiveness) to that agent on a presence-questionnaire. Attribution must exceed disembodied-baseline conditions.",
      "measurementSchema": "Slater-Usoh-Steed-style presence questionnaire adapted for embodied AI agents (8 items, 7-point Likert) administered after embodied and disembodied sessions in counterbalanced order. Presence-delta = embodied-mean minus disembodied-mean per sub-scale.",
      "exampleData": "{\"participant_id\": \"P066\", \"embodied_presence_mean\": 5.4, \"disembodied_presence_mean\": 3.1, \"presence_delta\": 2.3, \"subscale_strongest\": \"here-ness\", \"session_order_counterbalanced\": true}",
      "broader": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-agentic-ai",
      "inScheme": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-agentic-ai",
      "mainEntityOfPage": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0914.html",
      "citation": "https://zenodo.org/communities/augmanitai",
      "position": 2,
      "relatedTerm": [
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0859.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0860.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0888.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0889.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0944.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0921.html"
      ],
      "inclusionCriteria": "Both embodied and disembodied conditions completed with presence-delta above 1.0 on at least one sub-scale.",
      "exclusionCriteria": "Sessions with technical agent-failure exceeding 10% of session-duration."
    },
    {
      "@type": "DefinedTerm",
      "@id": "https://augmanitai.com/terms/AUG-0888",
      "name": "Human-in-the-Loop",
      "description": "Der Mensch als Kontrollinstanz im autonomen Regelkreis. Aufsicht als Designprinzip.",
      "inDefinedTermSet": "https://augmanitai.com/terms/periodic/",
      "termCode": "AUG-0888",
      "alternateName": "HIL",
      "inLanguage": "de",
      "about": "AG",
      "operationalDefinition": "Human-in-the-Loop operation is observed when a human gate-keeps at-least one decision-point in an otherwise automated AI workflow, with the gate-decision documented and the upstream AI proposal modified in at least 15% of cases. Gates must be inserted at non-trivial decision-points.",
      "measurementSchema": "Click-through-rate per affordance analysis on the human-gate UI: proportion of AI-proposals approved without change, modified, rejected, and escalated. Time-on-task per subtask recorded for each gate-decision. Modification-rate as primary loop-effectiveness metric.",
      "exampleData": "{\"workflow_id\": \"WF-029\", \"participant\": \"P106\", \"gate_decisions_n\": 64, \"approve_no_change_pct\": 0.58, \"modify_pct\": 0.27, \"reject_pct\": 0.11, \"escalate_pct\": 0.04, \"mean_time_per_gate_s\": 18}",
      "broader": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-agentic-ai",
      "inScheme": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-agentic-ai",
      "mainEntityOfPage": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0888.html",
      "citation": "https://zenodo.org/communities/augmanitai",
      "position": 3,
      "relatedTerm": [
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0859.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0860.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0914.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0944.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0889.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0915.html"
      ],
      "inclusionCriteria": "Modification rate above 15% across at least 30 gate-decisions on non-trivial decision-points.",
      "exclusionCriteria": "Rubber-stamp gates where the human approves above 95% of proposals without inspection."
    },
    {
      "@type": "DefinedTerm",
      "@id": "https://augmanitai.com/terms/AUG-0889",
      "name": "Agent Ensemble",
      "description": "Zusammenspiel mehrerer Agenten unter menschlicher Aufsicht. Orchestrierung statt Einzelsteuerung.",
      "inDefinedTermSet": "https://augmanitai.com/terms/periodic/",
      "termCode": "AUG-0889",
      "alternateName": "AEN",
      "inLanguage": "de",
      "about": "AG",
      "operationalDefinition": "Operational scope: an instance of 'Agent Ensemble' is counted when the observable pattern described above (Zusammenspiel mehrerer Agenten unter menschlicher Aufsicht. Orchestrierung statt...) occurs at least once within a defined interaction segment of N turns (typically N=10), as coded by trained raters.",
      "measurementSchema": "Initiative-event count (AI-initiated actions per N turns); complementary indicator: override-rate.",
      "exampleData": "{\"session_id\": \"S001\", \"ai_initiative_count_per_10_turns\": 3, \"override_rate\": 0.10}",
      "broader": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-agentic-ai",
      "inScheme": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-agentic-ai",
      "mainEntityOfPage": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0889.html",
      "citation": "https://zenodo.org/communities/augmanitai",
      "position": 3,
      "relatedTerm": [
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0859.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0860.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0914.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0921.html",

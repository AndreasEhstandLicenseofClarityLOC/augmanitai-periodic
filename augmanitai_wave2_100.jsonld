    {
      "@type": "DefinedTerm",
      "@id": "https://augmanitai.com/terms/AUG-0847",
      "name": "Digital Native Dialogue",
      "description": "Generationengespraech ueber KI zwischen Digital Natives und frueheren Generationen. Gegenseitiges Lernen statt Spaltung.",
      "inDefinedTermSet": "https://augmanitai.com/terms/periodic/",
      "termCode": "AUG-0847",
      "alternateName": "DND",
      "inLanguage": "de",
      "about": "GS",
      "operationalDefinition": "Digital Native Dialogue is observed when participants who grew up with always-on digital environments employ distinctive AI-interaction conventions (compressed syntax, platform-jargon, multimedia inline) that differ measurably from digital-immigrant patterns.",
      "measurementSchema": "HEXACO 6-factor personality administered alongside cohort-marker (birth-year as proxy for digital-native status) and a 12-feature interaction-style vector. Discriminant function analysis identifying native-vs-immigrant signature; classification accuracy reported.",
      "exampleData": "{\"participants_n\": 84, \"native_cohort_n\": 41, \"immigrant_cohort_n\": 43, \"discriminant_accuracy_pct\": 78, \"wilks_lambda\": 0.42, \"hexaco_openness_native_mean\": 4.6}",
      "broader": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-society-culture",
      "inScheme": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-society-culture",
      "mainEntityOfPage": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0847.html",
      "citation": "https://zenodo.org/communities/augmanitai",
      "position": 5,
      "relatedTerm": [
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0119.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0010.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0198.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0730.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0099.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0093.html"
      ],
      "inclusionCriteria": "Birth-year recorded AND at least 5000 words of AI-interaction text per participant.",
      "exclusionCriteria": "Bilingual code-switching participants where compressed-syntax may reflect language rather than cohort."
    },
    {
      "@type": "DefinedTerm",
      "@id": "https://augmanitai.com/terms/AUG-0071",
      "name": "Epistemic Hygiene",
      "description": "Bezeichnung fuer systematische Pruefprozesse von KI-generiertem Wissen: Quellen pruefen, triangulieren, einordnen.",
      "inDefinedTermSet": "https://augmanitai.com/terms/periodic/",
      "termCode": "AUG-0071",
      "alternateName": "EPH",
      "inLanguage": "de",
      "about": "MT",
      "operationalDefinition": "Epistemic Hygiene is observed when a participant routinely verifies AI-provided factual claims against an independent source before action or onward sharing. Operationalised through a verification-log capturing claim, source-checked, and verification-outcome.",
      "measurementSchema": "Verification-log audit over 14 days: verification-rate = (verified claims) / (verifiable factual claims received); source-quality coded on a 3-tier scale (primary / secondary / tertiary). Reported alongside time-to-verify per claim.",
      "exampleData": "{\"participant_id\": \"P010\", \"window_days\": 14, \"factual_claims_received\": 52, \"verifications_performed\": 38, \"verification_rate\": 0.73, \"mean_time_to_verify_s\": 47, \"primary_source_pct\": 0.42}",
      "broader": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-meta-reflection",
      "inScheme": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-meta-reflection",
      "mainEntityOfPage": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0071.html",
      "citation": "https://zenodo.org/communities/augmanitai",
      "position": 3,
      "relatedTerm": [
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0075.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0076.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0024.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0145.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0078.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0011.html"
      ],
      "inclusionCriteria": "Verification logged with source-reference for a factual claim received from AI.",
      "exclusionCriteria": "Verifications of opinions, preferences, or already-known facts."
    },
    {
      "@type": "DefinedTerm",
      "@id": "https://augmanitai.com/terms/AUG-0075",
      "name": "The Gardener Protocol",
      "description": "Wissen wird gepflegt wie ein Garten: regelmaessig pruefen, sortieren, aktualisieren und Unkraut entfernen.",
      "inDefinedTermSet": "https://augmanitai.com/terms/periodic/",
      "termCode": "AUG-0075",
      "alternateName": "GDP",
      "inLanguage": "de",
      "about": "MT",
      "operationalDefinition": "Gardener Protocol behaviour is observed when a participant systematically curates and prunes their AI-interaction history (chat logs, custom instructions, saved memories) on a recurring schedule rather than allowing accumulation, evidenced by curation-events logged with a stated rationale.",
      "measurementSchema": "Curation-log analysis over 30 days: curation-frequency (events per week), action-type distribution (delete / archive / annotate / restructure), and rationale-articulation rate. Health-index = (curation-frequency x rationale-rate) normalised.",
      "exampleData": "{\"participant_id\": \"P016\", \"window_days\": 30, \"curation_events\": 12, \"per_week\": 2.8, \"delete_pct\": 0.35, \"annotate_pct\": 0.4, \"rationale_articulation_rate\": 0.83}",
      "broader": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-meta-reflection",
      "inScheme": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-meta-reflection",
      "mainEntityOfPage": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0075.html",
      "citation": "https://zenodo.org/communities/augmanitai",
      "position": 3,
      "relatedTerm": [
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0071.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0076.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0024.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0023.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0001.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0011.html"
      ],
      "inclusionCriteria": "Curation event with timestamp and stated rationale logged.",
      "exclusionCriteria": "One-off cleanup after a storage warning or platform-imposed deletion."
    },
    {
      "@type": "DefinedTerm",
      "@id": "https://augmanitai.com/terms/AUG-0076",
      "name": "Self-Referential Grounding",
      "description": "Verankerung im eigenen Wertesystem als Orientierung in der KI-Interaktion.",
      "inDefinedTermSet": "https://augmanitai.com/terms/periodic/",
      "termCode": "AUG-0076",
      "alternateName": "SRG",
      "inLanguage": "de",
      "about": "MT",
      "operationalDefinition": "Self-Referential Grounding is observed when a participant anchors AI-mediated reasoning to their own first-person experience or stated values, evidenced by recurrent self-reference markers ('in my experience', 'for me', 'my values say') that appear at decision-points rather than throughout the transcript.",
      "measurementSchema": "Lexical-diversity index (MTLD) applied to self-reference markers across transcript segments, paired with positional analysis (proportion of self-references at decision-points vs filler turns). Grounding-index = MTLD(self-refs) x decision-point-concentration ratio.",
      "exampleData": "{\"session_id\": \"S088\", \"participant\": \"P037\", \"self_ref_count\": 18, \"mtld_self_refs\": 64.2, \"decision_point_concentration\": 0.71, \"grounding_index\": 45.6}",
      "broader": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-meta-reflection",
      "inScheme": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-meta-reflection",
      "mainEntityOfPage": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0076.html",
      "citation": "https://zenodo.org/communities/augmanitai",
      "position": 3,
      "relatedTerm": [
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0071.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0075.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0024.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0145.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0011.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0001.html"
      ],
      "inclusionCriteria": "Self-reference markers appearing at identified decision-points with lexical diversity above MTLD 50.",
      "exclusionCriteria": "Generic conversational self-references that do not anchor a decision or value judgement."
    },
    {
      "@type": "DefinedTerm",
      "@id": "https://augmanitai.com/terms/AUG-0024",
      "name": "Built-In Compass",
      "description": "Innere Orientierung aus Werten, Erfahrung und Intuition, die als natuerliches KI-Korrektiv dient.",
      "inDefinedTermSet": "https://augmanitai.com/terms/periodic/",
      "termCode": "AUG-0024",
      "alternateName": "BIC",
      "inLanguage": "de",
      "about": "MT",
      "operationalDefinition": "A Built-In Compass is observed when a participant returns to a consistent set of orienting principles across diverse AI-mediated decisions, evidenced by recurrent invocation of the same value-anchors in transcript analysis across at least 5 distinct decision-contexts.",
      "measurementSchema": "Hofstede dimensions coding scheme applied to value-anchor invocations in transcripts: each anchor tagged with cultural-value dimension (e.g., individualism, uncertainty-avoidance, long-term-orientation). Compass-consistency = entropy of distribution across decisions; low entropy = stable compass.",
      "exampleData": "{\"participant_id\": \"P094\", \"decisions_n\": 8, \"anchors_invoked\": 21, \"dimensions_used\": 4, \"entropy_bits\": 1.6, \"dominant_dimension\": \"long-term-orientation\"}",
      "broader": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-meta-reflection",
      "inScheme": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-meta-reflection",
      "mainEntityOfPage": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0024.html",
      "citation": "https://zenodo.org/communities/augmanitai",
      "position": 3,
      "relatedTerm": [
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0071.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0075.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0076.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0102.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0023.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0001.html"
      ],
      "inclusionCriteria": "Anchor invocations across at least 5 distinct decision-contexts with entropy below 2.0 bits.",
      "exclusionCriteria": "Single-domain decisions where the compass would be domain-confounded rather than truly stable."
    },
    {
      "@type": "DefinedTerm",
      "@id": "https://augmanitai.com/terms/AUG-0011",
      "name": "Reflective Operator",
      "description": "Nutzertyp der beobachtbar die eigene KI-Nutzung reflektiert und bewusst weiterentwickelt.",
      "inDefinedTermSet": "https://augmanitai.com/terms/periodic/",
      "termCode": "AUG-0011",
      "alternateName": "RFO",
      "inLanguage": "de",
      "about": "MT",
      "operationalDefinition": "Operational scope: an instance of 'Reflective Operator' is counted when the observable pattern described above (Nutzertyp der beobachtbar die eigene KI-Nutzung reflektiert und bewusst weiteren...) occurs at least once within a defined interaction segment of N turns (typically N=10), as coded by trained raters.",
      "measurementSchema": "Coding-scheme occurrence count; observer agreement (Cohen's κ).",

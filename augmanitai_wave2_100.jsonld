  "hasDefinedTerm": [
    {
      "@type": "DefinedTerm",
      "@id": "https://augmanitai.com/terms/AUG-0004",
      "name": "Zero-Point Self",
      "description": "Ausgangszustand des Wissens vor jeglicher KI-Nutzung. Persoenliche Referenzlinie.",
      "inDefinedTermSet": "https://augmanitai.com/terms/periodic/",
      "termCode": "AUG-0004",
      "alternateName": "ZPS",
      "inLanguage": "de",
      "about": "KG",
      "operationalDefinition": "Zero-Point Self is recorded when a participant reports a baseline identity-state distinct from AI-augmented states, articulated as the self-experience present in the absence of any external cognitive aid. Operationalised via a structured self-report protocol contrasting augmented and unaugmented sessions.",
      "measurementSchema": "Within-subject A/B design: two 30-minute reflection sessions (A=AI-augmented, B=unaided), each followed by a 12-item identity-distinctness questionnaire (5-point Likert). Primary metric: B-A difference in self-continuity sub-scale.",
      "exampleData": "{\"participant_id\": \"P006\", \"session_A_continuity\": 4.1, \"session_B_continuity\": 4.6, \"B_minus_A\": 0.5, \"questionnaire_alpha\": 0.83, \"session_order\": \"B_first\"}",
      "broader": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-cognition-thought",
      "inScheme": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-cognition-thought",
      "mainEntityOfPage": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0004.html",
      "citation": "https://zenodo.org/communities/augmanitai",
      "position": 1,
      "relatedTerm": [
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0054.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0002.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0007.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0035.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0098.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0089.html"
      ],
      "inclusionCriteria": "Both sessions completed with valid questionnaire responses and a discernible state-contrast.",
      "exclusionCriteria": "Sessions where the unaided condition was contaminated by incidental AI use (logged via device-monitoring)."
    },
    {
      "@type": "DefinedTerm",
      "@id": "https://augmanitai.com/terms/AUG-0054",
      "name": "Augmented Understanding",
      "description": "Beobachtbarer Moment erweiterter Informationszugaenglichkeit durch KI-gestuetzte Recherche.",
      "inDefinedTermSet": "https://augmanitai.com/terms/periodic/",
      "termCode": "AUG-0054",
      "alternateName": "AUN",
      "inLanguage": "de",
      "about": "KG",
      "operationalDefinition": "Augmented Understanding is recorded when a participant demonstrates improved comprehension of a target concept after AI-mediated explanation, measured by pre-post comprehension delta on a domain-specific concept-inventory administered before and after the AI interaction.",
      "measurementSchema": "Pre-post quasi-experimental design with validated concept-inventory (10-15 items per domain). Primary metric: normalized gain g = (post - pre) / (max - pre). Secondary: self-rated understanding on 7-point Likert at both timepoints.",
      "exampleData": "{\"participant_id\": \"P038\", \"domain\": \"statistics\", \"pre_score\": 6, \"post_score\": 11, \"max_score\": 15, \"normalized_gain_g\": 0.56, \"likert_delta\": 2.5}",
      "broader": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-cognition-thought",
      "inScheme": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-cognition-thought",
      "mainEntityOfPage": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0054.html",
      "citation": "https://zenodo.org/communities/augmanitai",
      "position": 1,
      "relatedTerm": [
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0004.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0002.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0007.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0016.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0089.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0035.html"
      ],
      "inclusionCriteria": "Positive normalized gain g > 0.2 on a validated concept-inventory tied to the AI session.",
      "exclusionCriteria": "Gains attributable to test-retest familiarity without AI exposure (assessed via control arm)."
    },
    {
      "@type": "DefinedTerm",
      "@id": "https://augmanitai.com/terms/AUG-0002",
      "name": "Mentale Externalisierung",
      "description": "Gezielte Auslagerung von Denkprozessen an ein KI-System, um Raum fuer genuines menschliches Denken zu schaffen.",
      "inDefinedTermSet": "https://augmanitai.com/terms/periodic/",
      "termCode": "AUG-0002",
      "alternateName": "MES",
      "inLanguage": "de",
      "about": "KG",
      "operationalDefinition": "Mental Externalisation is recorded when a participant transfers an internally held thought, plan, or memory into an external AI-mediated artifact (chat-log, structured note, list) and subsequently references that artifact instead of re-retrieving from memory. Operationally measured by externalisation-events and retrieval-source per task.",
      "measurementSchema": "Externalisation-event log over a 7-day window with timestamps; paired with source-of-retrieval coding (internal recall vs external lookup) on a follow-up recall task. Reliance-ratio = external-lookups / (external-lookups + internal-recalls).",
      "exampleData": "{\"participant_id\": \"P022\", \"window_days\": 7, \"externalisation_events\": 34, \"internal_recalls\": 12, \"external_lookups\": 28, \"reliance_ratio\": 0.7}",
      "broader": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-cognition-thought",
      "inScheme": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-cognition-thought",
      "mainEntityOfPage": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0002.html",
      "citation": "https://zenodo.org/communities/augmanitai",
      "position": 2,
      "relatedTerm": [
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0004.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0054.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0007.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0089.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0051.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0088.html"
      ],
      "inclusionCriteria": "Documented transfer of a cognitive item into an external AI-mediated artifact with later retrieval.",
      "exclusionCriteria": "Routine note-taking without subsequent retrieval, or paper-only externalisation without AI mediation."
    },
    {
      "@type": "DefinedTerm",
      "@id": "https://augmanitai.com/terms/AUG-0007",
      "name": "The Blending Effect",
      "description": "Eigene Gedanken und KI-generierter Inhalt verbinden sich zu einem gemeinsamen Ergebnis. Ein Zuordnungsphaenomen, kein Verlustphaenomen.",
      "inDefinedTermSet": "https://augmanitai.com/terms/periodic/",
      "termCode": "AUG-0007",
      "alternateName": "BLE",
      "inLanguage": "de",
      "about": "KG",
      "operationalDefinition": "The Blending Effect is observed when ideas originating from the participant and from the AI become indistinguishable in a final output, verified by a source-attribution task in which neither the participant nor an external rater can reliably assign passages back to their origin above chance.",
      "measurementSchema": "Source-attribution forced-choice task: independent raters assign passage-origin (human vs AI vs blend) on n=30 passages from joint outputs. Blending detected when accuracy approaches chance (33% in three-class case); signal-detection-theory d-prime computed for blend-vs-pure discrimination.",
      "exampleData": "{\"output_id\": \"OUT-021\", \"participant\": \"P076\", \"passages_n\": 30, \"rater_accuracy\": 0.41, \"d_prime\": 0.18, \"blend_pct_perceived\": 0.55}",
      "broader": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-cognition-thought",
      "inScheme": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-cognition-thought",
      "mainEntityOfPage": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0007.html",
      "citation": "https://zenodo.org/communities/augmanitai",
      "position": 2,
      "relatedTerm": [
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0004.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0054.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0002.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0098.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0205.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0043.html"
      ],
      "inclusionCriteria": "Rater accuracy at or near chance with d-prime below 0.5 on the blend-vs-pure discrimination.",
      "exclusionCriteria": "Outputs with explicit attribution markers or distinct stylistic fingerprints recoverable above chance."
    },
    {
      "@type": "DefinedTerm",
      "@id": "https://augmanitai.com/terms/AUG-0035",
      "name": "Epistemic Half-Life",
      "description": "Beobachtbare Zeitspanne, in der KI-generierte Information aktuell bleibt. Beschreibt ein Verfallsmuster.",
      "inDefinedTermSet": "https://augmanitai.com/terms/periodic/",
      "termCode": "AUG-0035",
      "alternateName": "EHL",
      "inLanguage": "de",
      "about": "KG",
      "operationalDefinition": "Operational scope: an instance of 'Epistemic Half-Life' is counted when the observable pattern described above (Beobachtbare Zeitspanne, in der KI-generierte Information aktuell bleibt. Beschr...) occurs at least once within a defined interaction segment of N turns (typically N=10), as coded by trained raters.",
      "measurementSchema": "Coding-scheme occurrence count; observer agreement (Cohen's κ).",
      "exampleData": "{\"session_id\": \"S001\", \"occurrence_count\": 5, \"kappa\": 0.74}",
      "broader": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-cognition-thought",
      "inScheme": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-cognition-thought",
      "mainEntityOfPage": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0035.html",
      "citation": "https://zenodo.org/communities/augmanitai",
      "position": 2,
      "relatedTerm": [
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0004.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0054.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0002.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0007.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0088.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0051.html"
      ]
    },
    {
      "@type": "DefinedTerm",
      "@id": "https://augmanitai.com/terms/AUG-0043",
      "name": "Just-in-Time Competence",
      "description": "Beobachtetes Muster situationsbezogenen Wissenszugriffs durch KI-Unterstuetzung.",
      "inDefinedTermSet": "https://augmanitai.com/terms/periodic/",
      "termCode": "AUG-0043",
      "alternateName": "JTC",
      "inLanguage": "de",
      "about": "KG",
      "operationalDefinition": "Operational scope: an instance of 'Just-in-Time Competence' is counted when the observable pattern described above (Beobachtetes Muster situationsbezogenen Wissenszugriffs durch KI-Unterstuetzung....) occurs at least once within a defined interaction segment of N turns (typically N=10), as coded by trained raters.",
      "measurementSchema": "Coding-scheme occurrence count; observer agreement (Cohen's κ).",
      "exampleData": "{\"session_id\": \"S001\", \"occurrence_count\": 5, \"kappa\": 0.74}",
      "broader": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-cognition-thought",
      "inScheme": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-cognition-thought",
      "mainEntityOfPage": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0043.html",
      "citation": "https://zenodo.org/communities/augmanitai",
      "position": 2,
      "relatedTerm": [
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0004.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0054.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0002.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0098.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0205.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0088.html"
      ]
    },
    {
      "@type": "DefinedTerm",
      "@id": "https://augmanitai.com/terms/AUG-0088",
      "name": "Algorithmic Intuition",
      "description": "Beobachtbare Mustererkennung bei erfahrenen KI-Nutzern: wiederkehrende Interaktionsmuster werden schneller erkannt.",
      "inDefinedTermSet": "https://augmanitai.com/terms/periodic/",
      "termCode": "AUG-0088",
      "alternateName": "ALI",
      "inLanguage": "de",
      "about": "KG",
      "operationalDefinition": "Algorithmic Intuition is recorded when a participant produces a correct or near-correct prediction of an AI system's output before viewing it, accompanied by a verbal rationale that references prior interaction patterns rather than guessing. Operationally instantiated as a pre-output prediction task with confidence rating.",
      "measurementSchema": "Prediction-accuracy task: participants predict AI output on n=20 standardized prompts before reveal, scored by semantic-similarity (BERTScore) between prediction and actual output. Confidence reported on 5-point scale per item. Composite score = accuracy x confidence calibration.",
      "exampleData": "{\"session_id\": \"S031\", \"participant\": \"P003\", \"prompts_n\": 20, \"mean_bertscore\": 0.71, \"mean_confidence\": 3.8, \"calibration_error\": 0.12, \"experience_months\": 14}",
      "broader": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-cognition-thought",
      "inScheme": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-cognition-thought",
      "mainEntityOfPage": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0088.html",
      "citation": "https://zenodo.org/communities/augmanitai",
      "position": 3,
      "relatedTerm": [
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0004.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0054.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0002.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0051.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0043.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0089.html"
      ],
      "inclusionCriteria": "Pre-output prediction grounded in stated prior-interaction reasoning.",
      "exclusionCriteria": "Random guesses or predictions made after partial output reveal."
    },
    {
      "@type": "DefinedTerm",
      "@id": "https://augmanitai.com/terms/AUG-0016",
      "name": "Poly-Categorical Mesh",
      "description": "KI-gestuetzte Verknuepfung von Wissen aus verschiedenen Fachbereichen zu neuen, fachuebergreifenden Ergebnissen.",
      "inDefinedTermSet": "https://augmanitai.com/terms/periodic/",
      "termCode": "AUG-0016",
      "alternateName": "PCM",
      "inLanguage": "de",
      "about": "KG",
      "operationalDefinition": "A Poly-Categorical Mesh is observed when a participant's AI-mediated reasoning traverses multiple overlapping ontological categories within a single task without category-collapse, evidenced by category-tag analysis of transcript segments and by network-density measures on the resulting tag-graph.",
      "measurementSchema": "Tag-graph network analysis: each transcript-segment tagged with one or more ontological categories from a controlled vocabulary, then graph constructed with categories as nodes and co-occurrence as edges. Mesh-density = edge-count / (nodes choose 2); fragmentation-resistance = largest-connected-component ratio.",
      "exampleData": "{\"task_id\": \"T078\", \"participant\": \"P109\", \"transcript_segments\": 84, \"categories_invoked\": 12, \"edges\": 28, \"mesh_density\": 0.42, \"lcc_ratio\": 0.94}",
      "broader": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-cognition-thought",
      "inScheme": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-cognition-thought",
      "mainEntityOfPage": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0016.html",
      "citation": "https://zenodo.org/communities/augmanitai",
      "position": 3,
      "relatedTerm": [
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0004.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0054.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0002.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0088.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0035.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0007.html"
      ],
      "inclusionCriteria": "Mesh-density above 0.3 with largest-connected-component ratio above 0.8 across at least 50 transcript segments.",
      "exclusionCriteria": "Single-category dominant tasks where mesh-density is artificially inflated by repeat-tagging of one category."
    },
    {
      "@type": "DefinedTerm",
      "@id": "https://augmanitai.com/terms/AUG-0051",
      "name": "Depth of Provenance",
      "description": "Die Faehigkeit, die Herkunft und Zuverlaessigkeit von KI-generiertem Wissen systematisch zu bewerten und einzuordnen.",
      "inDefinedTermSet": "https://augmanitai.com/terms/periodic/",
      "termCode": "AUG-0051",
      "alternateName": "DOP",
      "inLanguage": "de",
      "about": "KG",
      "operationalDefinition": "Operational scope: an instance of 'Depth of Provenance' is counted when the observable pattern described above (Die Faehigkeit, die Herkunft und Zuverlaessigkeit von KI-generiertem Wissen syst...) occurs at least once within a defined interaction segment of N turns (typically N=10), as coded by trained raters.",
      "measurementSchema": "Coding-scheme occurrence count; observer agreement (Cohen's κ).",
      "exampleData": "{\"session_id\": \"S001\", \"occurrence_count\": 5, \"kappa\": 0.74}",
      "broader": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-cognition-thought",
      "inScheme": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-cognition-thought",
      "mainEntityOfPage": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0051.html",
      "citation": "https://zenodo.org/communities/augmanitai",
      "position": 3,
      "relatedTerm": [
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0004.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0054.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0002.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0205.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0035.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0007.html"
      ]
    },
    {
      "@type": "DefinedTerm",
      "@id": "https://augmanitai.com/terms/AUG-0089",
      "name": "The Pattern Sharpening",
      "description": "Beobachtbare Veraenderung in Denkmustern bei regelmaessiger KI-Nutzung. Ein dokumentiertes Interaktionsphaenomen.",
      "inDefinedTermSet": "https://augmanitai.com/terms/periodic/",
      "termCode": "AUG-0089",
      "alternateName": "PTS",
      "inLanguage": "de",
      "about": "KG",
      "operationalDefinition": "The Pattern Sharpening is observed when iterative AI exchange reduces the noise-to-signal ratio in a participant's working representation of a recurring pattern, evidenced by progressive narrowing of the variance in pattern-defining features across successive articulations within one session.",
      "measurementSchema": "Time-series autocorrelation function (ACF) computed on feature-vectors extracted per turn from the participant's pattern-description statements. Sharpening = monotonic decrease in feature-variance with positive lag-1 autocorrelation rho >= 0.6 indicating coherent narrowing.",
      "exampleData": "{\"session_id\": \"S145\", \"participant\": \"P062\", \"turns_analysed\": 14, \"initial_variance\": 0.82, \"final_variance\": 0.21, \"acf_lag1\": 0.71}",
      "broader": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-cognition-thought",
      "inScheme": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-cognition-thought",
      "mainEntityOfPage": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0089.html",
      "citation": "https://zenodo.org/communities/augmanitai",
      "position": 4,
      "relatedTerm": [
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0004.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0054.html",

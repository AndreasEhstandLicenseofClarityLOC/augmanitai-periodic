        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0962.html"
      ],
      "inclusionCriteria": "Constraint present in at least 8 of 9 sessions with stable pupillometry signature and zero relaxation-events.",
      "exclusionCriteria": "Constraints that are mechanically enforced by the platform rather than participant-held."
    },

    {
      "@type": "DefinedTerm",
      "@id": "https://augmanitai.com/terms/AUG-0981",
      "name": "Companion Pattern",
      "description": "KI als wiederkehrendes Arbeitswerkzeug. Beobachtbar etablieren sich individuelle Nutzungsmuster und bevorzugte Ablaeufe.",
      "inDefinedTermSet": "https://augmanitai.com/terms/periodic/",
      "termCode": "AUG-0981",
      "alternateName": "CPP",
      "inLanguage": "de",
      "about": "RL",
      "operationalDefinition": "The Companion Pattern is observed when AI-interaction frequency and duration display covariation with the participant's social-availability signals (low when social-network active, high when social-network sparse), measured across at least 60 days of paired data.",
      "measurementSchema": "Mediation analysis via Hayes PROCESS macro (Model 4) with social-network-density as predictor, AI-session-duration as outcome, and perceived-loneliness as mediator. Indirect effect bootstrap CI reported.",
      "exampleData": "{\"participant\": \"P024\", \"observation_days\": 84, \"social_network_density_range\": \"[0.12, 0.71]\", \"indirect_effect_b\": 0.34, \"bootstrap_ci_95\": \"[0.18, 0.52]\", \"mediation_significant\": true}",
      "broader": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-relation-trust",
      "inScheme": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-relation-trust",
      "mainEntityOfPage": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0981.html",
      "citation": "https://zenodo.org/communities/augmanitai",
      "position": 3,
      "relatedTerm": [
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0566.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0539.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0170.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0201.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0177.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0197.html"
      ],
      "inclusionCriteria": "Paired daily social-network and AI-usage data over >= 60 days.",
      "exclusionCriteria": "Participants with stable social-network density (variance < 0.05)."
    },
    {

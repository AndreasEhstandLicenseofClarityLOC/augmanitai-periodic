    {
      "@type": "DefinedTerm",
      "@id": "https://augmanitai.com/terms/AUG-0020",
      "name": "Recursive Feedback Loop",
      "description": "Iterative Vertiefung: KI-Output wird bearbeitet, zurueckgegeben, weiterentwickelt. Progressive Verfeinerung.",
      "inDefinedTermSet": "https://augmanitai.com/terms/periodic/",
      "termCode": "AUG-0020",
      "alternateName": "RFL",
      "inLanguage": "de",
      "about": "AV",
      "operationalDefinition": "A Recursive Feedback Loop is recorded when a participant iteratively refines an AI output by feeding modifications back into the next prompt at least three times within a single task, with each iteration measurably altering the AI response. Each cycle must reference content from the prior cycle.",
      "measurementSchema": "Iteration-count per task plus edit-distance (Levenshtein) between successive AI outputs. Loop-quality coded on a 4-point rubric (1=no change, 2=surface edit, 3=substantive refinement, 4=structural reframe). Convergence detected when consecutive edit-distances drop below 10% of initial.",
      "exampleData": "{\"task_id\": \"T012\", \"participant\": \"P027\", \"iterations\": 6, \"mean_edit_distance\": 142, \"convergence_iteration\": 5, \"mean_loop_quality\": 3.2}",
      "broader": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-work-behavior",
      "inScheme": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-work-behavior",
      "mainEntityOfPage": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0020.html",
      "citation": "https://zenodo.org/communities/augmanitai",
      "position": 2,
      "relatedTerm": [
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0005.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0008.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0021.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0133.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0018.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0095.html"
      ],
      "inclusionCriteria": "Three or more iterations each referencing prior cycle content with measurable AI-output change.",
      "exclusionCriteria": "Repeated identical prompts or simple typo-corrections without content change."
    },
    {
      "@type": "DefinedTerm",
      "@id": "https://augmanitai.com/terms/AUG-0005",
      "name": "Integrated Operator",
      "description": "Beobachtbarer Arbeitsstil: Integration von KI in Denk- und Arbeitsprozesse mit fliessenden Uebergaengen.",
      "inDefinedTermSet": "https://augmanitai.com/terms/periodic/",
      "termCode": "AUG-0005",
      "alternateName": "INO",
      "inLanguage": "de",
      "about": "AV",
      "operationalDefinition": "An Integrated Operator is observed when a participant blends AI-assistance fluidly into a primary task such that AI-mediated steps are not separable into distinct sub-tasks, evidenced by uninterrupted task-flow telemetry and post-task think-aloud reports treating AI as embedded rather than tool-like.",
      "measurementSchema": "Task-flow telemetry: mean time between AI-handoff and task-resumption (target < 8s); think-aloud coding for AI-as-tool vs AI-as-extension framing on a 5-point integration scale. Composite integration-index = (1 - normalized handoff-time) x integration-scale-mean.",
      "exampleData": "{\"task_id\": \"T029\", \"participant\": \"P014\", \"ai_handoffs\": 22, \"mean_handoff_time_s\": 5.4, \"integration_scale_mean\": 4.1, \"integration_index\": 0.78}",
      "broader": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-work-behavior",
      "inScheme": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-work-behavior",
      "mainEntityOfPage": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0005.html",
      "citation": "https://zenodo.org/communities/augmanitai",
      "position": 3,
      "relatedTerm": [
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0020.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0008.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0021.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0138.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0095.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0091.html"
      ],
      "inclusionCriteria": "Both telemetry and think-aloud data captured for the same task with consistent integration signals.",
      "exclusionCriteria": "Tasks where AI is consciously bracketed as a separate tool (explicit pause-consult-resume pattern)."
    },
    {
      "@type": "DefinedTerm",
      "@id": "https://augmanitai.com/terms/AUG-0008",
      "name": "Polyphonic Sovereign",
      "description": "Bewusste Orchestrierung mehrerer KI-Systeme, deren Perspektiven gegeneinander geprueft werden.",
      "inDefinedTermSet": "https://augmanitai.com/terms/periodic/",
      "termCode": "AUG-0008",
      "alternateName": "PCS",
      "inLanguage": "de",
      "about": "AV",
      "operationalDefinition": "Polyphonic Sovereign behaviour is recorded when a participant simultaneously queries two or more distinct AI systems on the same task, weighs the divergent outputs, and produces an integrated decision with explicit reference to each source. Source-tracking must be observable in the participant's notes or transcript.",
      "measurementSchema": "Multi-source coding: count of AI-sources consulted per decision, weighting-explicitness score (0-3), and divergence-handling rubric (averaging / pick-best / synthesise / reject-all). Reported per decision with source-diversity index = number of distinct providers.",
      "exampleData": "{\"decision_id\": \"D018\", \"participant\": \"P035\", \"sources_consulted\": 3, \"source_diversity\": 3, \"weighting_explicitness\": 2, \"divergence_strategy\": \"synthesise\"}",
      "broader": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-work-behavior",
      "inScheme": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-work-behavior",
      "mainEntityOfPage": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0008.html",
      "citation": "https://zenodo.org/communities/augmanitai",
      "position": 3,
      "relatedTerm": [
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0020.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0005.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0021.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0133.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0134.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0018.html"
      ],
      "inclusionCriteria": "Two or more AI sources consulted with documented weighting on a single decision.",
      "exclusionCriteria": "Sequential queries to the same system or unweighted last-source-wins behaviour."
    },
    {
      "@type": "DefinedTerm",
      "@id": "https://augmanitai.com/terms/AUG-0021",
      "name": "Initialization Cascade",
      "description": "Die persoenliche Eroeffnungssequenz einer KI-Sitzung. Erfahrene Nutzer entwickeln eigene Startmuster.",
      "inDefinedTermSet": "https://augmanitai.com/terms/periodic/",
      "termCode": "AUG-0021",
      "alternateName": "INC",
      "inLanguage": "de",
      "about": "AV",
      "operationalDefinition": "An Initialization Cascade is observed when the first 3-5 turns of an AI session set framings, vocabulary, or constraints that propagate measurably through subsequent turns even after topic-shifts. Cascade-strength is operationalised by token-overlap between initialization-window and downstream turns.",
      "measurementSchema": "BLEU-score / METEOR computed between the initialization-window text (turns 1-5) and each subsequent turn-block (turns 6-10, 11-15, etc). Cascade-strength = mean BLEU across blocks; decay-rate fitted via exponential regression.",
      "exampleData": "{\"session_id\": \"S158\", \"participant\": \"P085\", \"init_window_turns\": 5, \"downstream_blocks\": 6, \"mean_bleu\": 0.34, \"meteor_mean\": 0.41, \"decay_half_life_turns\": 18}",
      "broader": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-work-behavior",
      "inScheme": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-work-behavior",
      "mainEntityOfPage": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0021.html",
      "citation": "https://zenodo.org/communities/augmanitai",
      "position": 3,
      "relatedTerm": [
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0020.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0005.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0008.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0133.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0018.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0138.html"
      ],
      "inclusionCriteria": "Mean BLEU above 0.15 across at least 4 downstream blocks with measurable decay-pattern.",
      "exclusionCriteria": "Sessions with explicit context-reset commands that flush the initialization-window."
    },
    {
      "@type": "DefinedTerm",

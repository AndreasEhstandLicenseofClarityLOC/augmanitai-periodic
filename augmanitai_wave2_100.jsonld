    {
      "@type": "DefinedTerm",
      "@id": "https://augmanitai.com/terms/AUG-0092",
      "name": "Output Asymmetry",
      "description": "Beobachtbares Verhaeltnis zwischen Input-Aufwand und Output-Umfang bei KI-gestuetzter Arbeit.",
      "inDefinedTermSet": "https://augmanitai.com/terms/periodic/",
      "termCode": "AUG-0092",
      "alternateName": "OAS",
      "inLanguage": "de",
      "about": "AV",
      "operationalDefinition": "Output Asymmetry is observed when AI produces systematically different output-quality across nominally equivalent input-formulations, measured by output-quality distribution differences between paraphrased prompt pairs.",
      "measurementSchema": "Wilcoxon rank-sum test on output-quality scores between paraphrased prompt pairs, with effect-size r reported. Asymmetry detected when r > 0.3 with p < 0.05 across n >= 30 paraphrased pairs.",
      "exampleData": "{\"session_id\": \"S066\", \"paraphrase_pairs\": 32, \"wilcoxon_W\": 287, \"p_value\": 0.011, \"effect_size_r\": 0.41, \"asymmetry_direction\": \"format-A-favored\"}",
      "broader": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-work-behavior",
      "inScheme": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-work-behavior",
      "mainEntityOfPage": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0092.html",
      "citation": "https://zenodo.org/communities/augmanitai",
      "position": 4,
      "relatedTerm": [
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0020.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0005.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0008.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0021.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0018.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0138.html"
      ],
      "inclusionCriteria": "At least 30 paraphrased prompt pairs scored by blind raters.",
      "exclusionCriteria": "Pairs where paraphrase introduces semantic shift greater than 0.15 cosine-distance."
    },
    {
      "@type": "DefinedTerm",
      "@id": "https://augmanitai.com/terms/AUG-0095",
      "name": "One-Person Operation",
      "description": "Beobachtbares Phaenomen: KI-Unterstuetzung erschliesst Einzelpersonen Produktivitaet, die vorher nur groesseren Teams zugaenglich war.",
      "inDefinedTermSet": "https://augmanitai.com/terms/periodic/",
      "termCode": "AUG-0095",
      "alternateName": "OPO",
      "inLanguage": "de",
      "about": "AV",
      "operationalDefinition": "One-Person Operation is observed when a single individual delivers, via AI-augmentation, work-outputs that would conventionally require a multi-person team, measured by output-volume and quality against multi-person benchmarks.",
      "measurementSchema": "Psychological Capital Questionnaire (PCQ-24) administered alongside Data Envelopment Analysis (DEA) of output-efficiency: inputs = solo-operator hours, outputs = quality-weighted deliverable-volume; technical-efficiency score (0-1) compared to team-baseline efficient frontier. One-Person index = DEA efficiency x PsyCap composite.",
      "exampleData": "{\"operator_id\": \"OP004\", \"pcq24_score\": 4.6, \"dea_technical_efficiency\": 0.91, \"team_baseline_frontier_efficiency\": 0.72, \"quality_weighted_output_units\": 38, \"one_person_index\": 4.19}",
      "broader": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-work-behavior",
      "inScheme": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-work-behavior",
      "mainEntityOfPage": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0095.html",
      "citation": "https://zenodo.org/communities/augmanitai",
      "position": 5,
      "relatedTerm": [
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0020.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0005.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0008.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0091.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0018.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0092.html"
      ],
      "inclusionCriteria": "Operator with >= 30 days of solo-AI output AND PCQ-24 completed.",
      "exclusionCriteria": "Outputs requiring physical co-presence or in-person handoffs."
    },
    {
      "@type": "DefinedTerm",
      "@id": "https://augmanitai.com/terms/AUG-0031",
      "name": "Semantic Spark",
      "description": "KI-Antwort loest unerwarteten eigenen Gedanken aus. Nicht die Antwort ist die Loesung, sondern der Funke, den sie zuendet.",
      "inDefinedTermSet": "https://augmanitai.com/terms/periodic/",
      "termCode": "AUG-0031",
      "alternateName": "SSP",
      "inLanguage": "de",
      "about": "SY",
      "operationalDefinition": "A Semantic Spark is recorded when an AI utterance triggers a participant-reported associative leap to a previously unconnected concept within 30 seconds, verified by a verbal trace linking the trigger phrase to the resulting concept and an absence of that concept in the preceding 10 turns.",
      "measurementSchema": "Stimulated-recall protocol: participants flag spark-moments in real-time via a single keypress; researcher then asks for the trigger-phrase and the associated concept. Sparks-per-hour computed; novelty verified against a 10-turn lookback window using lexical-overlap analysis.",
      "exampleData": "{\"session_id\": \"S023\", \"participant\": \"P008\", \"duration_min\": 45, \"spark_events\": 7, \"sparks_per_hour\": 9.3, \"mean_trigger_token_count\": 6, \"novelty_verified_pct\": 86}",
      "broader": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-system-behavior",
      "inScheme": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-system-behavior",
      "mainEntityOfPage": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0031.html",
      "citation": "https://zenodo.org/communities/augmanitai",
      "position": 1,
      "relatedTerm": [
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0084.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0030.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0524.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0126.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0142.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0107.html"
      ],
      "inclusionCriteria": "Real-time flag plus verbal trigger-trace plus 10-turn novelty verification.",
      "exclusionCriteria": "Sparks where the linked concept appeared in the preceding 10 turns."
    },
    {
      "@type": "DefinedTerm",
      "@id": "https://augmanitai.com/terms/AUG-0084",
      "name": "Glitch-Mining",
      "description": "KI-Fehler als Ressource: was ein Glitch ueber das System verraet, kann wertvoller sein als eine korrekte Antwort.",
      "inDefinedTermSet": "https://augmanitai.com/terms/periodic/",
      "termCode": "AUG-0084",
      "alternateName": "GLM",
      "inLanguage": "de",
      "about": "SY",
      "operationalDefinition": "Glitch-Mining is observed when a participant intentionally probes AI behaviour at edge-cases (ambiguous prompts, contradictory framings, out-of-distribution queries) and logs the resulting failure-modes for analysis. Activity is operationalised by structured probe-logs with hypothesis-result pairs.",
      "measurementSchema": "Probe-log analysis: count of edge-case probes per session, hypothesis-articulation rate (proportion with stated expectation), and failure-detection rate (proportion where AI output deviates from sensible baseline as judged by two raters).",
      "exampleData": "{\"session_id\": \"S072\", \"participant\": \"P031\", \"probes_n\": 18, \"hypothesised_probes\": 14, \"failures_detected\": 7, \"failure_rate\": 0.39, \"rater_agreement\": 0.88}",
      "broader": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-system-behavior",
      "inScheme": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-system-behavior",
      "mainEntityOfPage": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0084.html",
      "citation": "https://zenodo.org/communities/augmanitai",
      "position": 1,
      "relatedTerm": [
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0031.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0030.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0524.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0142.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0135.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0107.html"
      ],
      "inclusionCriteria": "Documented probe with prior hypothesis and adjudicated outcome.",
      "exclusionCriteria": "Casual unstructured complaints about AI errors without prior hypothesis."
    },
    {
      "@type": "DefinedTerm",
      "@id": "https://augmanitai.com/terms/AUG-0030",
      "name": "Contextual Gravity",
      "description": "Mit wachsendem Kontext entwickelt eine KI-Sitzung eine natuerliche thematische Schwerkraft.",
      "inDefinedTermSet": "https://augmanitai.com/terms/periodic/",
      "termCode": "AUG-0030",
      "alternateName": "COG",
      "inLanguage": "de",
      "about": "SY",
      "operationalDefinition": "Contextual Gravity is observed when prior context-elements in a session (earlier messages, established persona, named entities) exert measurable pull on subsequent AI outputs such that later responses regress toward earlier framings even after explicit topic-shift. The effect is operationalised through within-session context-anchor probes inserted at fixed positions.",
      "measurementSchema": "Granger causality test between time-lagged context-anchor features (e.g., earlier persona-tokens) and downstream AI-output features (lexical, stylistic). Pull-strength reported as F-statistic with effect-size for each anchor-target pair across a sliding window.",
      "exampleData": "{\"session_id\": \"S112\", \"participant\": \"P044\", \"anchors_inserted\": 6, \"granger_f_stat_mean\": 4.7, \"pull_significant_pct\": 0.67, \"max_lag_turns\": 12}",
      "broader": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-system-behavior",
      "inScheme": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-system-behavior",
      "mainEntityOfPage": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0030.html",
      "citation": "https://zenodo.org/communities/augmanitai",
      "position": 2,
      "relatedTerm": [
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0031.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0084.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0524.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0107.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0135.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0176.html"
      ],
      "inclusionCriteria": "Context-anchor present in early turns with downstream AI-output measurably influenced (Granger p less than 0.05).",
      "exclusionCriteria": "Anchors that are explicitly re-cited by the user in later turns, removing the pull-signal."
    },
    {
      "@type": "DefinedTerm",
      "@id": "https://augmanitai.com/terms/AUG-0524",
      "name": "The Context Layer",
      "description": "Der aufgebaute Kontext als Arbeitsschicht: je praeziser der Kontext, desto besser die Ergebnisse.",
      "inDefinedTermSet": "https://augmanitai.com/terms/periodic/",
      "termCode": "AUG-0524",
      "alternateName": "CTL",
      "inLanguage": "de",
      "about": "SY",
      "operationalDefinition": "A Context Layer is observed when a participant deliberately scaffolds session-context with structured preamble (role, constraints, examples, format-spec) before issuing task-prompts, with the preamble producing measurable downstream output-quality gains versus an unscaffolded baseline.",
      "measurementSchema": "Within-subject A/B test on n=20 task-pairs: same task with scaffolded vs unscaffolded preamble. Output quality scored on a 5-point rubric per task and analysed via System Usability Scale (SUS) administered after scaffolded vs unscaffolded conditions. Recall-test percentage on task-constraints applied at session end as secondary outcome.",
      "exampleData": "{\"participant_id\": \"P088\", \"task_pairs\": 20, \"scaffolded_quality_mean\": 4.1, \"unscaffolded_quality_mean\": 3.2, \"sus_score_scaffolded\": 82, \"sus_score_unscaffolded\": 64, \"constraint_recall_pct\": 0.85}",
      "broader": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-system-behavior",
      "inScheme": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-system-behavior",
      "mainEntityOfPage": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0524.html",
      "citation": "https://zenodo.org/communities/augmanitai",
      "position": 2,
      "relatedTerm": [
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0031.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0084.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0030.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0142.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0135.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0176.html"
      ],
      "inclusionCriteria": "All 20 task-pairs completed with paired-t significant scaffold-effect (p less than 0.05) and SUS-delta above 10 points in favour of scaffolded condition.",
      "exclusionCriteria": "Tasks where the scaffold itself contains the task-solution rather than framing context."
    },
    {

    {
      "@type": "DefinedTerm",
      "@id": "https://augmanitai.com/terms/AUG-0046",
      "name": "The Felt Echo",
      "description": "Emotionaler Nachhall einer intensiven KI-Sitzung. Das Erlebnis klingt nach, die Gedanken arbeiten weiter.",
      "inDefinedTermSet": "https://augmanitai.com/terms/periodic/",
      "termCode": "AUG-0046",
      "alternateName": "FEC",
      "inLanguage": "de",
      "about": "EM",
      "operationalDefinition": "A Felt Echo is recorded when a participant reports a somatic or affective resonance (warmth, recognition, mild emotional response) following a specific AI utterance, verified by self-report rating greater than 4 on a 7-point affective-resonance scale within 60 seconds of the trigger turn.",
      "measurementSchema": "Event-marked self-report: participant taps marker at resonance-moment, then completes 4-item resonance-scale (recognition / warmth / surprise / poignancy). Echo-rate = markers per hour; depth = mean scale-score per event.",
      "exampleData": "{\"session_id\": \"S091\", \"participant\": \"P040\", \"duration_min\": 50, \"echo_events\": 4, \"echoes_per_hour\": 4.8, \"mean_resonance_depth\": 5.3, \"strongest_dimension\": \"recognition\"}",
      "broader": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-emotion-affect",
      "inScheme": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-emotion-affect",
      "mainEntityOfPage": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0046.html",
      "citation": "https://zenodo.org/communities/augmanitai",
      "position": 1,
      "relatedTerm": [
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0025.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0127.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0168.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0081.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0301.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0128.html"
      ],
      "inclusionCriteria": "Real-time marker with completed scale response greater than 4 on at least one dimension within 60s.",
      "exclusionCriteria": "Retrospective reports without an event-marker or post-hoc rationalisation."
    },
    {
      "@type": "DefinedTerm",
      "@id": "https://augmanitai.com/terms/AUG-0025",
      "name": "The Offload Lift",
      "description": "Beobachtbare emotionale Reaktion beim Delegieren aufwaendiger Aufgaben an KI. Ein Interaktionsphaenomen.",
      "inDefinedTermSet": "https://augmanitai.com/terms/periodic/",
      "termCode": "AUG-0025",
      "alternateName": "OFL",
      "inLanguage": "de",
      "about": "EM",
      "operationalDefinition": "An Offload Lift is recorded when a participant transfers a cognitive or emotional burden (a worry, an unfinished task, a recurring thought) to an AI system in writing and subsequently reports reduced burden-intensity, verified by pre-post burden-rating on a standardised scale.",
      "measurementSchema": "Pre-post burden-rating on a 0-100 visual analogue scale, administered immediately before and 10 minutes after the offload-event. Lift = drop of at least 15 points. Persistence assessed by re-rating at 24 hours.",
      "exampleData": "{\"event_id\": \"E057\", \"participant\": \"P012\", \"burden_pre\": 78, \"burden_post_10min\": 54, \"burden_24h\": 61, \"drop_10min\": 24, \"lift_persisted_24h\": true}",
      "broader": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-emotion-affect",
      "inScheme": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-emotion-affect",
      "mainEntityOfPage": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0025.html",
      "citation": "https://zenodo.org/communities/augmanitai",
      "position": 1,
      "relatedTerm": [
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0046.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0127.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0168.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0301.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0128.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0529.html"
      ],
      "inclusionCriteria": "Documented offload-event with at-least 15-point drop on the 0-100 scale at 10 minutes.",
      "exclusionCriteria": "Multi-topic sessions where the offloaded burden cannot be cleanly isolated."
    },
    {
      "@type": "DefinedTerm",
      "@id": "https://augmanitai.com/terms/AUG-0127",
      "name": "Expansion Feeling",
      "description": "Beobachtbares Erleben waehrend intensiver KI-Nutzung. Die eigenen Denkgrenzen scheinen sich auszudehnen.",
      "inDefinedTermSet": "https://augmanitai.com/terms/periodic/",
      "termCode": "AUG-0127",
      "alternateName": "EXF",
      "inLanguage": "de",
      "about": "EM",
      "operationalDefinition": "An Expansion Feeling is recorded when a participant reports a phenomenologically distinct sense of perceived possibility or scope-broadening following an AI exchange, rated greater than or equal to 5 on a 7-point expansion-scale across two sub-dimensions (perceived options + perceived agency).",
      "measurementSchema": "Two-sub-scale rating (5 items per sub-scale, 7-point Likert) administered immediately after target exchanges. Expansion event = both sub-scale means greater than or equal to 5. Frequency reported per 10 sessions; composite expansion-score = mean of both sub-scales.",
      "exampleData": "{\"session_id\": \"S104\", \"participant\": \"P028\", \"options_subscale_mean\": 5.8, \"agency_subscale_mean\": 5.4, \"composite_expansion\": 5.6, \"exchange_topic\": \"career_planning\"}",
      "broader": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-emotion-affect",
      "inScheme": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-emotion-affect",
      "mainEntityOfPage": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0127.html",
      "citation": "https://zenodo.org/communities/augmanitai",
      "position": 1,
      "relatedTerm": [
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0046.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0025.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0168.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0081.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0128.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0245.html"
      ],
      "inclusionCriteria": "Both sub-scales scoring at least 5 in the immediate post-exchange rating.",
      "exclusionCriteria": "Sessions following explicit brainstorming-protocol prompts where expansion is the instructed goal."
    },
    {
      "@type": "DefinedTerm",
      "@id": "https://augmanitai.com/terms/AUG-0168",
      "name": "Rehumanization Moment",
      "description": "Beobachtbarer Moment bewusster Rueckkehr zu nicht-KI-gestuetzter Taetigkeit nach intensiver KI-Arbeit.",
      "inDefinedTermSet": "https://augmanitai.com/terms/periodic/",
      "termCode": "AUG-0168",
      "alternateName": "RHM",
      "inLanguage": "de",
      "about": "EM",
      "operationalDefinition": "A Rehumanization Moment is recorded when a participant who has previously expressed dehumanising or instrumentalising framing of others shifts to a humanising framing within or shortly after an AI-mediated reflective exchange, verified by linguistic-shift analysis on participant text.",
      "measurementSchema": "PANAS (Positive and Negative Affect Schedule) administered pre and post, paired with linguistic-dehumanisation-scale coding of participant text (mechanistic vs animalistic vs humanising terms). Shift = negative-PANAS drop with humanising-term frequency increase.",
      "exampleData": "{\"participant_id\": \"P082\", \"panas_neg_pre\": 28, \"panas_neg_post\": 17, \"humanising_term_rate_pre\": 0.12, \"humanising_term_rate_post\": 0.34, \"shift_detected\": true}",
      "broader": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-emotion-affect",
      "inScheme": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-emotion-affect",
      "mainEntityOfPage": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0168.html",
      "citation": "https://zenodo.org/communities/augmanitai",
      "position": 1,
      "relatedTerm": [
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0046.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0025.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0127.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0245.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0301.html",
        "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0081.html"
      ],
      "inclusionCriteria": "PANAS-negative drop above 8 points combined with humanising-term rate at least doubling.",
      "exclusionCriteria": "Sessions where the dehumanising framing was hypothetical or quoted from external source rather than participant-held."
    },
    {
      "@type": "DefinedTerm",
      "@id": "https://augmanitai.com/terms/AUG-0301",
      "name": "The Wonder Moment",
      "description": "Staunen ueber eine unerwartete KI-Leistung. Der Aha-Moment, der zeigt: das hat man nicht kommen sehen.",
      "inDefinedTermSet": "https://augmanitai.com/terms/periodic/",
      "termCode": "AUG-0301",
      "alternateName": "WOM",
      "inLanguage": "de",
      "about": "EM",
      "operationalDefinition": "Operational scope: an instance of 'The Wonder Moment' is counted when the observable pattern described above (Staunen ueber eine unerwartete KI-Leistung. Der Aha-Moment, der zeigt: das hat m...) occurs at least once within a defined interaction segment of N turns (typically N=10), as coded by trained raters.",
      "measurementSchema": "Sensor-coupling latency (ms) between human action and AI response in physical/multimodal channels.",
      "exampleData": "{\"session_id\": \"S001\", \"sensor_coupling_latency_ms\": 47, \"n_actions\": 20}",
      "broader": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-emotion-affect",
      "inScheme": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-emotion-affect",
      "mainEntityOfPage": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0301.html",
      "citation": "https://zenodo.org/communities/augmanitai",

    {
      "@type": "DefinedTerm",
      "@id": "https://augmanitai.com/terms/AUG-0944",
      "name": "Autonomy Ladder",
      "description": "Stufenmodell zunehmender Agentenautonomie: von menschlich gesteuert bis autonom mit menschlichem Veto.",
      "inDefinedTermSet": "https://augmanitai.com/terms/periodic/",
      "termCode": "AUG-0944",
      "alternateName": "AUL",
      "inLanguage": "de",
      "about": "AG",
      "operationalDefinition": "Operational scope: an instance of 'Autonomy Ladder' is counted when the observable pattern described above (Stufenmodell zunehmender Agentenautonomie: von menschlich gesteuert bis autonom ...) occurs at least once within a defined interaction segment of N turns (typically N=10), as coded by trained raters.",
      "measurementSchema": "Initiative-event count (AI-initiated actions per N turns); complementary indicator: override-rate.",
      "exampleData": "{\"session_id\": \"S001\", \"ai_initiative_count_per_10_turns\": 3, \"override_rate\": 0.10}",

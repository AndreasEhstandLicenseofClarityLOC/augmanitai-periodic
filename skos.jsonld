      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0888",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Human-in-the-Loop",
        "@language": "en"
      },
      "skos:notation": "AUG-0888",
      "skos:definition": {
        "@value": "An established interaction-design pattern in which a human acts as a supervisory checkpoint within an otherwise automated decision loop, retaining the ability to review or intervene; a superordinate design concept rather than a single countable occurrence.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": {
        "@value": "HIL",
        "@language": "de"
      },
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-agentic-ai"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0859.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0860.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0914.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0888.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0889",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Agent Ensemble",
        "@language": "en"
      },
      "skos:notation": "AUG-0889",
      "skos:definition": {
        "@value": "A configuration in which several AI agents operate jointly on a task under human supervision, characterised by coordination among the agents and a human orchestration role; a structural property of the setup rather than a discrete event.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": {
        "@value": "AEN",
        "@language": "de"
      },
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-agentic-ai"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0859.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0860.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0914.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0889.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0868",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "The Rollback Option",
        "@language": "en"
      },
      "skos:notation": "AUG-0868",
      "skos:definition": {
        "@value": "A property of a control architecture in which AI-initiated actions can be reversed to a prior state, characterised by the availability and coverage of undo or restore mechanisms across the system's actions; an affordance rather than a discrete event.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": {
        "@value": "RBO",
        "@language": "de"
      },
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-agentic-ai"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0859.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0860.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0914.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0868.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0921",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Swarm Access",
        "@language": "en"
      },
      "skos:notation": "AUG-0921",
      "skos:definition": {
        "@value": "A condition in which a user can draw on the combined capacity of multiple networked agents under human supervision, treated as a graded property of the available capability rather than as a discrete event or a scaling claim.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": {
        "@value": "SWA",
        "@language": "de"
      },
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-agentic-ai"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0859.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0860.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0914.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0921.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0915",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Embodiment Effect",
        "@language": "en"
      },
      "skos:notation": "AUG-0915",
      "skos:definition": {
        "@value": "An observed difference in interaction dynamics associated with an AI system having a physical, embodied form versus a text-only form; reported as a measurable contrast condition rather than asserted as a fixed causal law.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": {
        "@value": "EMB",
        "@language": "de"
      },
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-agentic-ai"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0859.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0860.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0914.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0915.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0944",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Autonomy Ladder",
        "@language": "en"
      },
      "skos:notation": "AUG-0944",
      "skos:definition": {
        "@value": "A staged classification of increasing agent autonomy, ordering arrangements from fully human-controlled through to agent-autonomous with a reserved human veto; a superordinate ordinal scheme used to locate cases rather than a countable occurrence.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": {
        "@value": "AUL",
        "@language": "de"
      },
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-agentic-ai"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0859.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0860.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0914.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0944.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0954",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Congruence Review",
        "@language": "en"
      },
      "skos:notation": "AUG-0954",
      "skos:definition": {
        "@value": "A periodic review in which an AI system's observed behaviour is checked for continued correspondence with its intended goals and constraints; distinguished by a documented review occurrence that compares behaviour against a stated specification.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": {
        "@value": "CNR",
        "@language": "de"
      },
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-safety-alignment"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0009.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0632.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0951.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0954.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0009",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "The Speed Limit",
        "@language": "en"
      },
      "skos:notation": "AUG-0009",
      "skos:definition": {
        "@value": "A working condition in which the pace of an AI-supported task is kept within the rate at which the human can review the outputs, described as the relationship between output throughput and human checking capacity rather than as advice.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": {
        "@value": "SPL",
        "@language": "de"
      },
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-safety-alignment"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0954.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0632.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0951.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0009.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0632",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "The Offline Moment",
        "@language": "en"
      },
      "skos:notation": "AUG-0632",
      "skos:definition": {
        "@value": "A discrete instance of a user deliberately ending or stepping away from AI interaction, marking a boundary in the work session; distinguished from incidental gaps by being an intentional disengagement.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": {
        "@value": "OFM",
        "@language": "de"
      },
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-safety-alignment"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0954.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0009.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0951.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0632.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0951",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Value Constraint Encoding",
        "@language": "en"
      },
      "skos:notation": "AUG-0951",
      "skos:definition": {
        "@value": "A condition in which a set of intended human values is encoded into an autonomous system's operating constraints such that the system's behaviour remains bounded by them; described as the presence and coverage of such encoded constraints rather than as a guarantee.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": [
        {
          "@value": "Value Lock",
          "@language": "en"
        },
        {
          "@value": "VLO",
          "@language": "de"
        }
      ],
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-safety-alignment"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0954.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0009.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0632.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0951.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0962",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "The Pause Protocol",
        "@language": "en"
      },
      "skos:notation": "AUG-0962",
      "skos:definition": {
        "@value": "A discrete deliberate interruption inserted before a critical AI-supported decision, creating a checkpoint at which the human reconsiders before proceeding; distinguished by an observable hold step preceding the decision.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": {
        "@value": "PPR",
        "@language": "de"
      },
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-safety-alignment"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0954.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0009.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0632.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0962.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0120",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Range Framework",
        "@language": "en"
      },
      "skos:notation": "AUG-0120",
      "skos:definition": {
        "@value": "A defined usage boundary specifying what an AI system is permitted and not permitted to do within a given context, expressed as an explicit scope agreement; a superordinate governance construct rather than a per-interaction event.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": {
        "@value": "RAG",
        "@language": "de"
      },
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-safety-alignment"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0954.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0009.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0632.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0120.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0958",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Accountability Chain",
        "@language": "en"
      },
      "skos:notation": "AUG-0958",
      "skos:definition": {
        "@value": "A defined chain of responsibility specifying, across roles and levels, who decides, who reviews, and who is answerable for AI-supported outcomes; a superordinate governance structure rather than a discrete countable event.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": {
        "@value": "ACC",
        "@language": "de"
      },
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-safety-alignment"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0954.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0009.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0632.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0958.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0955",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Transparency Layer",
        "@language": "en"
      },
      "skos:notation": "AUG-0955",
      "skos:definition": {
        "@value": "A condition in which an AI system's processes and outputs are rendered inspectable and explainable to relevant parties, described as the graded extent of available, accurate disclosure rather than as a single event.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": {
        "@value": "TRL",
        "@language": "de"
      },
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-safety-alignment"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0954.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0009.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0632.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0955.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0771",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Minor Protection",
        "@language": "en"
      },
      "skos:notation": "AUG-0771",
      "skos:definition": {
        "@value": "A protective standard governing minors' interaction with AI systems, characterised by the presence and coverage of age-appropriate safeguards such as age assurance and content or contact restrictions; a graded property of a system's safeguards rather than a discrete event.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": {
        "@value": "MPR",
        "@language": "de"
      },
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-safety-alignment"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0954.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0009.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0632.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0771.html"
      }
    }
  ]

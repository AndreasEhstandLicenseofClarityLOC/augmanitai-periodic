      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0089",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "The Pattern Sharpening",
        "@language": "en"
      },
      "skos:notation": "AUG-0089",
      "skos:definition": {
        "@value": "A longitudinal effect in which regular AI interaction is associated with improvement in a user's ability to recognize patterns in data, texts, or arguments, such that sustained use coincides with gains in the person's own analytic pattern detection.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": {
        "@value": "PTS",
        "@language": "de"
      },
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-general-phenomenology"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0004.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0054.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0002.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0089.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0205",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "The Skill Unlock",
        "@language": "en"
      },
      "skos:notation": "AUG-0205",
      "skos:definition": {
        "@value": "An observable instance of completing, with AI support, a task belonging to a class the user could not previously accomplish unaided, marking newly reachable capability.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": {
        "@value": "SUL",
        "@language": "de"
      },
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-general-phenomenology"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0004.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0054.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0002.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0205.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0098",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Thinking Leverage",
        "@language": "en"
      },
      "skos:notation": "AUG-0098",
      "skos:definition": {
        "@value": "The relationship between the cognitive effort a user invests and the quality or quantity of output achieved with AI support; a ratio expressing output yield per unit of human input.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": {
        "@value": "THL",
        "@language": "de"
      },
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-general-phenomenology"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0004.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0054.html"

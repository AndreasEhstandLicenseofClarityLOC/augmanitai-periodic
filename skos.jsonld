      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0051",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Depth of Provenance",
        "@language": "en"
      },
      "skos:notation": "AUG-0051",
      "skos:definition": {
        "@value": "A graded user competence in evaluating the origin, evidential basis, and reliability of AI-generated knowledge and placing it appropriately, distinguishing well-sourced claims from unsupported ones.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": {
        "@value": "DOP",
        "@language": "de"
      },
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-general-phenomenology"
      },
      "skos:related": [

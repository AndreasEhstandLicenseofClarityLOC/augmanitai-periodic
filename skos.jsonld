    {
      "@id": "https://augmanitai.com/terms/AUG-0016",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Cross-Domain Synthesis",
        "@language": "en"
      },
      "skos:notation": "AUG-0016",
      "skos:definition": {
        "@value": "An output in which an AI-assisted user integrates knowledge from several distinct disciplines into a single interdisciplinary result. The referent is an instance of cross-domain synthesis produced with on-demand access to domain knowledge.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": [
        {
          "@value": "Poly-Categorical Mesh",
          "@language": "en"
        },
        {
          "@value": "PCM",
          "@language": "de"
        }
      ],
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-general-phenomenology"
      },
      "skos:related": [

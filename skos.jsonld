    {
      "@id": "https://augmanitai.com/terms/AUG-0007",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "The Blending Effect",
        "@language": "en"
      },
      "skos:notation": "AUG-0007",
      "skos:definition": {
        "@value": "Eigene Gedanken und KI-generierter Inhalt verbinden sich zu einem gemeinsamen Ergebnis. Ein Zuordnungsphaenomen, kein Verlustphaenomen.",
        "@language": "de"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",

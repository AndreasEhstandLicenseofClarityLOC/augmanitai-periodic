    {
      "@id": "https://augmanitai.com/terms/AUG-0004",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Zero-Point Self",
        "@language": "en"
      },
      "skos:notation": "AUG-0004",
      "skos:definition": {
        "@value": "A person's documented baseline of knowledge or skill in a domain prior to any AI assistance, used as the individual reference point against which later AI-supported performance is compared.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": {
        "@value": "ZPS",
        "@language": "de"
      },
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-general-phenomenology"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0054.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0002.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0007.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0004.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0054",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Augmented Understanding",
        "@language": "en"
      },
      "skos:notation": "AUG-0054",
      "skos:definition": {
        "@value": "An observable instance in which AI-assisted retrieval gives a user access to information they could not obtain unaided, evidenced by a measurable gain in comprehension or recall on the topic at hand.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": {
        "@value": "AUN",
        "@language": "de"
      },
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-general-phenomenology"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0004.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0002.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0007.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0054.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0002",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Cognitive Offloading Turn",
        "@language": "en"
      },
      "skos:notation": "AUG-0002",
      "skos:definition": {
        "@value": "A turn in which a user deliberately hands a discrete cognitive sub-task, such as enumeration, drafting, or calculation, to an AI system to reserve attention for other reasoning, observable as an explicit delegation request.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": [
        {
          "@value": "Mentale Externalisierung",
          "@language": "en"
        },
        {
          "@value": "MES",
          "@language": "de"
        }
      ],
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-general-phenomenology"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0004.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0054.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0007.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0002.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0007",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "The Blending Effect",
        "@language": "en"
      },
      "skos:notation": "AUG-0007",
      "skos:definition": {
        "@value": "A graded condition in which a user can no longer cleanly separate their own contributions from AI-generated material in a co-produced artifact; an attribution phenomenon about authorship boundaries, not a loss of ability.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": {
        "@value": "BLE",
        "@language": "de"
      },
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-general-phenomenology"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0004.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0054.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0002.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0007.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0035",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Information Currency Duration",
        "@language": "en"
      },
      "skos:notation": "AUG-0035",
      "skos:definition": {
        "@value": "The elapsed time over which a specific AI-generated factual claim stays accurate before external developments render it outdated; a duration describing how quickly such information loses currency.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": [
        {
          "@value": "Epistemic Half-Life",
          "@language": "en"
        },
        {
          "@value": "EHL",
          "@language": "de"
        }
      ],
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-general-phenomenology"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0004.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0054.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0002.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0035.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0043",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Just-in-Time Competence",
        "@language": "en"
      },
      "skos:notation": "AUG-0043",
      "skos:definition": {
        "@value": "An observable instance of accessing domain knowledge at the exact point of need through AI support, where the retrieved information immediately precedes and enables completion of the user's current task step.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": {
        "@value": "JTC",
        "@language": "de"
      },
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-general-phenomenology"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0004.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0054.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0002.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0043.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0088",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Algorithmic Intuition",
        "@language": "en"
      },
      "skos:notation": "AUG-0088",
      "skos:definition": {
        "@value": "An experienced user's implicit, practice-acquired sense for which kind of input tends to yield which kind of result, applied without deliberate analysis each time. Distinguished from explicit prompting knowledge by being tacit and predictive rather than reasoned step by step.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": {
        "@value": "ALI",
        "@language": "de"
      },
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-general-phenomenology"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0004.html"
        },
        {

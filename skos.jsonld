        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0002.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0098.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0156",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Articulation Unlock",
        "@language": "en"
      },
      "skos:notation": "AUG-0156",
      "skos:definition": {
        "@value": "An observable moment in which AI support helps a user put a pre-existing but unformed thought into words, evidenced by the user accepting a formulation that expresses an intent they had already signaled.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": {
        "@value": "ART",
        "@language": "de"
      },
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-general-phenomenology"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0403.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0513.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0478.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0156.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0403",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "The Translation Relief",
        "@language": "en"
      },
      "skos:notation": "AUG-0403",
      "skos:definition": {
        "@value": "A graded affective response of relief experienced by a user when AI support removes a language barrier and eases translation effort, reported by the user rather than inferred from the AI.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": {
        "@value": "TRR",
        "@language": "de"
      },
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-general-phenomenology"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0156.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0513.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0478.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0403.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0513",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Conversational Language-Practice Tool",
        "@language": "en"
      },
      "skos:notation": "AUG-0513",
      "skos:definition": {
        "@value": "A superordinate description of using an AI system as a repeatable language-practice resource that supplies correction and explanation alongside formal language instruction; a usage role rather than a single observable event.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": [
        {
          "@value": "The Language Buddy",
          "@language": "en"
        },
        {
          "@value": "LBD",
          "@language": "de"
        }
      ],
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-general-phenomenology"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0156.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0403.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0478.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0513.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0478",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "The Clarity Catalyst",
        "@language": "en"
      },
      "skos:notation": "AUG-0478",
      "skos:definition": {
        "@value": "An observable instance in which the demand to state a request explicitly to an AI prompts the user to reorganize their own understanding of a problem, changing the thinking process through the act of formulation.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": {
        "@value": "CLC",
        "@language": "de"
      },
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-general-phenomenology"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0156.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0403.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0513.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0478.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0188",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Tone Alignment",
        "@language": "en"
      },
      "skos:notation": "AUG-0188",
      "skos:definition": {
        "@value": "A longitudinal convergence between a user's communication style and the AI's responses over repeated exchanges, in which the pair settles into a shared workable register; a stylistic adaptation, not an emotional state of the AI.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": {
        "@value": "TAL",
        "@language": "de"
      },
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-general-phenomenology"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0156.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0403.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0513.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0188.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0169",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Second-Language Fluency",
        "@language": "en"
      },
      "skos:notation": "AUG-0169",
      "skos:definition": {
        "@value": "A graded condition of more successful foreign-language communication achieved with AI support, observed as eased production and comprehension in a second language during AI-assisted exchanges.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": {
        "@value": "SLF",
        "@language": "de"
      },
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-general-phenomenology"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0156.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0403.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0513.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0169.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0137",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Voice-First Protocol",
        "@language": "en"
      },
      "skos:notation": "AUG-0137",
      "skos:definition": {
        "@value": "A superordinate category for speech-based AI interaction treated as a distinct modality with its own affordances and dynamics, under which specific measurable voice-interaction phenomena are grouped.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": {
        "@value": "VOF",
        "@language": "de"
      },
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-general-phenomenology"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0156.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0403.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0513.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0137.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0267",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "The Language Unlock",
        "@language": "en"
      },
      "skos:notation": "AUG-0267",
      "skos:definition": {
        "@value": "An observable expansion of a user's active language repertoire through AI-assisted interaction, evidenced when a lexical or expressive item first encountered via the AI later appears in the user's own unaided production.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": {
        "@value": "LUN",
        "@language": "de"
      },
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-general-phenomenology"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0156.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0403.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0513.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0267.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0501",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "The Style Shifter",
        "@language": "en"
      },
      "skos:notation": "AUG-0501",
      "skos:definition": {
        "@value": "A graded user ability to deliberately switch among distinct writing styles with AI assistance and to access registers the user could not readily produce alone.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": {
        "@value": "SSF",
        "@language": "de"
      },
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-general-phenomenology"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0156.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0403.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0513.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0501.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0283",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "The Syntax Voice",
        "@language": "en"
      },
      "skos:notation": "AUG-0283",
      "skos:definition": {
        "@value": "The gradual incorporation of new sentence constructions and expressions, first encountered through AI interaction, into a user's own habitual syntactic repertoire over time.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": {
        "@value": "SVO",
        "@language": "de"
      },
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-general-phenomenology"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0156.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0403.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0513.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0283.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0046",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Post-Session Affective Residue",
        "@language": "en"
      },
      "skos:notation": "AUG-0046",
      "skos:definition": {
        "@value": "A residual affective and cognitive engagement persisting after an intense AI session, in which the user continues to feel the exchange and keeps processing its content for some time afterward; a post-session state of the user.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": [
        {
          "@value": "The Felt Echo",
          "@language": "en"
        },
        {
          "@value": "FEC",
          "@language": "de"
        }
      ],
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-embodied-ai"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0025.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0127.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0168.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0046.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0025",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "The Offload Lift",
        "@language": "en"
      },
      "skos:notation": "AUG-0025",
      "skos:definition": {
        "@value": "A graded affective response of relief or reduced burden experienced by a user when handing an effortful task to an AI system, reported as a felt easing of workload at the point of delegation.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": {
        "@value": "OFL",
        "@language": "de"
      },
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-embodied-ai"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0046.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0127.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0168.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0025.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0127",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Expansion Feeling",
        "@language": "en"
      },
      "skos:notation": "AUG-0127",
      "skos:definition": {
        "@value": "A subjective experience reported during intensive AI use in which a user perceives their own thinking boundaries as widening; a phenomenal state of the user, not a claim about expanded capacity in the AI.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": {
        "@value": "EXF",
        "@language": "de"
      },
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-embodied-ai"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0046.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0025.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0168.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0127.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0168",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Non-AI Activity Transition",
        "@language": "en"
      },
      "skos:notation": "AUG-0168",
      "skos:definition": {
        "@value": "An observable moment of deliberately returning to a non-AI activity after a period of intensive AI-assisted work, marking an intentional disengagement from the AI for a human-only task.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": [
        {
          "@value": "Rehumanization Moment",
          "@language": "en"
        },
        {
          "@value": "RHM",
          "@language": "de"
        }
      ],
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-embodied-ai"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0046.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0025.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0127.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0168.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0301",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Capability-Surprise Reaction",
        "@language": "en"
      },
      "skos:notation": "AUG-0301",
      "skos:definition": {
        "@value": "A discrete user reaction of surprise or astonishment occurring when an AI system produces output that exceeds the user's prior expectation of its capability. The reaction is a property of the human appraisal, not of the system.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": [
        {
          "@value": "The Wonder Moment",
          "@language": "en"
        },
        {
          "@value": "WOM",
          "@language": "de"
        }
      ],
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-embodied-ai"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0046.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0025.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0127.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0301.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0245",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Perceived-Understanding State",
        "@language": "en"
      },
      "skos:notation": "AUG-0245",
      "skos:definition": {
        "@value": "A graded subjective state in which a user judges an AI system's response to have accurately captured their intent or meaning. It denotes perceived understanding as reported by the user, not any mental state of the system.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": [
        {
          "@value": "The Seen Feeling",
          "@language": "en"
        },
        {
          "@value": "TSF",
          "@language": "de"
        }
      ],
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-embodied-ai"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0046.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0025.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0127.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0245.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0128",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "User-Directed Thanking",
        "@language": "en"
      },
      "skos:notation": "AUG-0128",
      "skos:definition": {
        "@value": "A discrete instance in which a user directs an expression of thanks toward an AI system following a response they found helpful. The behaviour is an observable politeness act by the user and implies nothing about the system.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": [
        {
          "@value": "The Gratitude Response",
          "@language": "en"
        },
        {
          "@value": "GRR",
          "@language": "de"
        }
      ],
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-embodied-ai"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0046.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0025.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0127.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0128.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0529",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Productive-Connection State",
        "@language": "en"
      },
      "skos:notation": "AUG-0529",
      "skos:definition": {
        "@value": "A graded user-reported sense of productive connection that arises while using an AI system to externalise and structure one's own thoughts. It describes a task-coupled affective state of the user, not a social relationship.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": [
        {
          "@value": "The Closeness Bridge",
          "@language": "en"
        },
        {
          "@value": "CLB",
          "@language": "de"
        }
      ],
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-embodied-ai"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0046.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0025.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0127.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0529.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0081",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Post-Authorial Pride",
        "@language": "en"
      },
      "skos:notation": "AUG-0081",
      "skos:definition": {
        "@value": "A graded user-reported feeling of pride in an artefact co-produced with an AI system. It is an affective appraisal the user holds toward a jointly produced output, distinct from sole-authorship pride.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": {
        "@value": "PAP",
        "@language": "de"
      },
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-embodied-ai"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0046.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0025.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0127.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0081.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0061",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Authorship-Attribution Query",
        "@language": "en"
      },
      "skos:notation": "AUG-0061",
      "skos:definition": {
        "@value": "A discrete instance in which a user explicitly raises the attribution question of which part of a co-produced output is their own contribution versus the AI system's. It marks an observable moment of authorship reflection.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": [
        {
          "@value": "Creator's Question",
          "@language": "en"
        },
        {
          "@value": "CRQ",
          "@language": "de"
        }
      ],
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-embodied-ai"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0046.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0025.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0127.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0061.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0020",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Recursive Feedback Loop",
        "@language": "en"
      },
      "skos:notation": "AUG-0020",
      "skos:definition": {
        "@value": "An interaction pattern in which AI output is edited by the user and returned for further processing across successive turns, producing progressive refinement of the artefact. It denotes an observable iterate-and-return turn sequence.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": {
        "@value": "RFL",
        "@language": "de"
      },
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-general-phenomenology"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0005.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0008.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0021.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0020.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0005",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "The Integrated Operator",
        "@language": "en"
      },
      "skos:notation": "AUG-0005",
      "skos:definition": {
        "@value": "A user mode in which a person no longer treats AI as a separate tool but moves fluidly between their own thinking and AI assistance without a distinct switching moment. The referent is an advanced, relatively stable working state characterised by low perceived separation between human and AI activity.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": {
        "@value": "INO",
        "@language": "de"
      },
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-general-phenomenology"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0020.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0008.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0021.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0005.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0008",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Multi-System Orchestration Style",
        "@language": "en"
      },
      "skos:notation": "AUG-0008",
      "skos:definition": {
        "@value": "A working style in which a user deliberately orchestrates several AI systems and cross-checks their differing outputs against one another. It is a graded profile of multi-system, comparison-driven use.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": [
        {
          "@value": "Polyphonic Sovereign",
          "@language": "en"
        },
        {
          "@value": "PCS",
          "@language": "de"
        }
      ],
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-general-phenomenology"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0020.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0005.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0021.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0008.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0021",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Initialization Cascade",
        "@language": "en"
      },
      "skos:notation": "AUG-0021",
      "skos:definition": {
        "@value": "A user's personalised opening sequence at the start of an AI session, in which experienced users deploy characteristic set-up moves before substantive work. It denotes an observable session-initiation routine.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": {
        "@value": "INC",
        "@language": "de"
      },
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-general-phenomenology"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0020.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0005.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0008.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0021.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0133",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Prompt Craftsmanship",
        "@language": "en"
      },
      "skos:notation": "AUG-0133",
      "skos:definition": {
        "@value": "A graded user skill in formulating effective AI inputs, developing with usage experience. It describes a measurable competence attributed to a person rather than a discrete interaction event.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": {
        "@value": "PMC",
        "@language": "de"
      },
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-general-phenomenology"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0020.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0005.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0008.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0133.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0134",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Context Window Awareness",
        "@language": "en"
      },
      "skos:notation": "AUG-0134",
      "skos:definition": {
        "@value": "A graded degree to which a user understands the mechanics of a model's context window and manages interaction strategically around its limits. It is an attributed knowledge-and-behaviour state of the user.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": {
        "@value": "CWA",
        "@language": "de"
      },
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-general-phenomenology"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0020.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0005.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0008.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0134.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0018",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Trinaug Protocol",
        "@language": "en"
      },
      "skos:notation": "AUG-0018",
      "skos:definition": {
        "@value": "A user method in which the same task is issued to three AI systems and the resulting outputs are compared to identify shared and divergent patterns. It denotes a discrete three-way comparison procedure.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": {
        "@value": "TRI",
        "@language": "de"
      },
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-general-phenomenology"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0020.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0005.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0008.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0018.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0138",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Session Architecture",
        "@language": "en"
      },
      "skos:notation": "AUG-0138",
      "skos:definition": {
        "@value": "Characteristic patterns by which users structure the flow of an AI session, with experienced users showing recognisable phase organisation. It describes a graded structural property of a session's organisation.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": {
        "@value": "SES",
        "@language": "de"
      },
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-general-phenomenology"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0020.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0005.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0008.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0138.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0091",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Productivity Arbitrage",
        "@language": "en"
      },
      "skos:notation": "AUG-0091",
      "skos:definition": {
        "@value": "The observed difference in task efficiency between AI-assisted and unassisted work processes for comparable tasks. It is a relational quantity comparing two performance conditions, not an event or feeling.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": {
        "@value": "PRO",
        "@language": "de"
      },
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-general-phenomenology"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0020.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0005.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0008.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0091.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0092",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Output Asymmetry",
        "@language": "en"
      },
      "skos:notation": "AUG-0092",
      "skos:definition": {
        "@value": "The relationship in which the effort needed to produce a result falls substantially under AI assistance while the quantity or quality of the result is maintained or increased. The referent is the changed ratio of input effort to output yield.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": {
        "@value": "OAS",
        "@language": "de"
      },
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-general-phenomenology"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0020.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0005.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0008.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0092.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0095",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "One-Person Operation",
        "@language": "en"
      },
      "skos:notation": "AUG-0095",
      "skos:definition": {
        "@value": "An observed condition in which AI assistance enables a single individual to reach a level of productive output previously requiring a larger team. It describes a capacity-expansion condition at the level of an individual operator.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": {
        "@value": "OPO",
        "@language": "de"
      },
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-general-phenomenology"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0020.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0005.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0008.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0095.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0031",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Idea-Trigger Event",
        "@language": "en"
      },
      "skos:notation": "AUG-0031",
      "skos:definition": {
        "@value": "A discrete instance in which an AI response triggers a new, unanticipated idea in the user, where the value lies in the thought it provokes rather than the answer itself. It marks an observable user-reported insight moment.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": [
        {
          "@value": "Semantic Spark",
          "@language": "en"
        },
        {
          "@value": "SSP",
          "@language": "de"
        }
      ],
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-general-phenomenology"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0084.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0030.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0524.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0031.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0084",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Glitch-Mining",
        "@language": "en"
      },
      "skos:notation": "AUG-0084",
      "skos:definition": {
        "@value": "A user practice of treating AI errors as informative, deliberately examining what a malfunction reveals about a system rather than discarding it. It denotes a discrete investigative use of an observed error.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": {
        "@value": "GLM",
        "@language": "de"
      },
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-general-phenomenology"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0031.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0030.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0524.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0084.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0030",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Contextual Gravity",
        "@language": "en"
      },
      "skos:notation": "AUG-0030",
      "skos:definition": {
        "@value": "The tendency of an AI session to develop an increasing thematic pull toward its accumulated context as that context grows over the course of the session. It describes a longitudinal drift in topical concentration.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": {
        "@value": "COG",
        "@language": "de"
      },
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-general-phenomenology"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0031.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0084.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0524.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0030.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0524",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "The Context Layer",
        "@language": "en"
      },
      "skos:notation": "AUG-0524",
      "skos:definition": {
        "@value": "The accumulated interaction context of a session treated as a working substrate that conditions subsequent system output. It is a superordinate organising concept spanning many context-related phenomena (such as how context is managed, accumulated, and reused) rather than a single observable occurrence.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": {
        "@value": "CTL",
        "@language": "de"
      },
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-general-phenomenology"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0031.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0084.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0030.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0524.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0176",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Capability Discovery",
        "@language": "en"
      },
      "skos:notation": "AUG-0176",
      "skos:definition": {
        "@value": "A discrete instance in which a user identifies a previously unknown capability of an AI system through exploration or experimentation. It marks an observable moment of first encountering a new affordance.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": {
        "@value": "CPD",
        "@language": "de"
      },
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-general-phenomenology"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0031.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0084.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0030.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0176.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0107",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Output-Verification Disposition",
        "@language": "en"
      },
      "skos:notation": "AUG-0107",
      "skos:definition": {
        "@value": "A user disposition toward systematically checking and contextualising AI results before relying on them. It describes a graded verification practice attributed to a user, distinct from any single checking act.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": [
        {
          "@value": "Verification Principle",
          "@language": "en"
        },
        {
          "@value": "VPR",
          "@language": "de"
        }
      ],
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-general-phenomenology"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0031.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0084.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0030.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0107.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0126",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Iterative Diminishing-Returns Point",
        "@language": "en"
      },
      "skos:notation": "AUG-0126",
      "skos:definition": {
        "@value": "The point in an iterative AI exchange at which further iteration ceases to add value, functioning as a signal to stop. It marks a discrete diminishing-returns threshold within a refinement sequence.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": [
        {
          "@value": "Semantic Saturation",
          "@language": "en"
        },
        {
          "@value": "SAT",
          "@language": "de"
        }
      ],
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-general-phenomenology"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0031.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0084.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0030.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0126.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0142",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Model Fingerprint",
        "@language": "en"
      },
      "skos:notation": "AUG-0142",
      "skos:definition": {
        "@value": "The recognisable stylistic signature of a given AI model, such that experienced users can identify which system produced a response. It describes a distinguishable stylistic property of a model's outputs.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": {
        "@value": "MFP",
        "@language": "de"
      },
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-general-phenomenology"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0031.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0084.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0030.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0142.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0135",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Persona Engineering",
        "@language": "en"
      },
      "skos:notation": "AUG-0135",
      "skos:definition": {
        "@value": "The deliberate shaping of an AI system's expressed persona via instructions to fit specific tasks or contexts. It denotes an observable user act of configuring system style, not a trait of the system itself.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": {
        "@value": "PEN",
        "@language": "de"
      },
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-general-phenomenology"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0031.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0084.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0030.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0135.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0006",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Platform Ontology",
        "@language": "en"
      },
      "skos:notation": "AUG-0006",
      "skos:definition": {
        "@value": "The set of systematic dispositions in a given AI system's outputs that derive from its training data and architecture, such that different systems produce characteristically different framings of the same prompt. A property attributed to a model configuration, not to a single reply.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": {
        "@value": "PLO",
        "@language": "de"
      },
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-general-phenomenology"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0031.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0084.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0030.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0006.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0566",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Ongoing Partnership",
        "@language": "en"
      },
      "skos:notation": "AUG-0566",
      "skos:definition": {
        "@value": "A longitudinal pattern in which a single user's repeated working interactions with one AI system show increasing efficiency or stability over time, such as shorter prompt-to-acceptable-output paths or more reused conventions across sessions.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": {
        "@value": "OGP",
        "@language": "de"
      },
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-general-phenomenology"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0539.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0170.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0177.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0566.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0539",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "The Companion Shift",
        "@language": "en"
      },
      "skos:notation": "AUG-0539",
      "skos:definition": {
        "@value": "A reported change over time in how an individual user characterizes an AI system, moving from describing it as a fixed single-task tool toward describing it as a flexible multi-purpose working instrument. Concerns the user's stated framing, not the system's properties.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": {
        "@value": "CPS",
        "@language": "de"
      },
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-general-phenomenology"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0566.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0170.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0177.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0539.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0170",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Articulation-to-System Effect",
        "@language": "en"
      },
      "skos:notation": "AUG-0170",
      "skos:definition": {
        "@value": "A user-reported experience of an AI system as an attentive interlocutor to which thoughts can be externalized, where the act of articulating to the system is rated as clarifying. The construct concerns the user's subjective report and ascribes no inner states to the system.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": [
        {
          "@value": "Witness Effect",
          "@language": "en"
        },
        {
          "@value": "WIT",
          "@language": "de"
        }
      ],
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-general-phenomenology"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0566.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0539.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0177.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0170.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0177",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "The Trust Setting",
        "@language": "en"
      },
      "skos:notation": "AUG-0177",
      "skos:definition": {
        "@value": "The graded level of reliance a user deliberately places on a given AI system's outputs for a class of tasks, expressed in how much independent verification the user applies before acting on those outputs. A consciously adjusted disposition rather than a fixed trait.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": {
        "@value": "TRS",
        "@language": "de"
      },
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-general-phenomenology"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0566.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0539.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0170.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0177.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0577",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Early-Interaction Alignment Curve",
        "@language": "en"
      },
      "skos:notation": "AUG-0577",
      "skos:definition": {
        "@value": "The early phase of a new user-system working relationship during which prompts and responses progressively align, observable as a decline in clarification exchanges and reformulations across the first several sessions before reaching a plateau.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": [
        {
          "@value": "The Calibration Dance",
          "@language": "en"
        },
        {
          "@value": "CDA",
          "@language": "de"
        }
      ],
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-general-phenomenology"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0566.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0539.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0170.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0577.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0161",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Invisible Colleague",
        "@language": "en"
      },
      "skos:notation": "AUG-0161",
      "skos:definition": {
        "@value": "A usage configuration in which an AI system functions as an on-demand background work aid that the user invokes for discrete subtasks without sustained turn-by-turn dialogue or social framing. Characterized by short, intermittent, task-bounded calls.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": {
        "@value": "INV",
        "@language": "de"
      },
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-general-phenomenology"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0566.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0539.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0170.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0161.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0981",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "The Companion Pattern",
        "@language": "en"
      },
      "skos:notation": "AUG-0981",
      "skos:definition": {
        "@value": "A standing usage mode in which a person incorporates AI assistance into daily routines as a steady accompaniment for thinking, drafting, and exploration, operating alongside rather than in place of their own reflection. The referent is the co-present, habitual mode of use.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": {
        "@value": "CPP",
        "@language": "de"
      },
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-general-phenomenology"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0566.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0539.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0170.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0981.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0197",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Sustained-Focus State",
        "@language": "en"
      },
      "skos:notation": "AUG-0197",
      "skos:definition": {
        "@value": "A user-reported state of sustained, undistracted concentration during a stretch of productive work with an AI system, in which the tool fades into the background of attention. The construct is the user's focus state, attributed to the person, not jointly to the system.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": [
        {
          "@value": "The Shared Quiet",
          "@language": "en"
        },
        {
          "@value": "SHQ",
          "@language": "de"
        }
      ],
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-general-phenomenology"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0566.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0539.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0170.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0197.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0201",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Low-Stakes Exploration Space",
        "@language": "en"
      },
      "skos:notation": "AUG-0201",
      "skos:definition": {
        "@value": "A reported use of AI interaction as a low-stakes space for structured exploration of one's own ideas, absent the social considerations of a human audience. The construct concerns the user's described use of the channel, not emotional closeness to the system.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": [
        {
          "@value": "The Closeness Bridge",
          "@language": "en"
        },
        {
          "@value": "CLB2",
          "@language": "de"
        }
      ],
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-general-phenomenology"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0566.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0539.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0170.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0201.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0080",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Relationship-First",
        "@language": "en"
      },
      "skos:notation": "AUG-0080",
      "skos:definition": {
        "@value": "A stated user value-orientation that places human relationships ahead of AI-assisted productivity when the two are in tension. As a superordinate guiding principle it organizes choices across situations rather than denoting a single observable interaction event.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": {
        "@value": "RFP",
        "@language": "de"
      },
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-general-phenomenology"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0566.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0539.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0170.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0080.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0119",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Level Playing Field",
        "@language": "en"
      },
      "skos:notation": "AUG-0119",
      "skos:definition": {
        "@value": "A population-level tendency for AI tools to widen access to knowledge and capabilities across user groups over time, such that gaps between previously advantaged and less advantaged groups on AI-mediated tasks narrow. A macro trend, not an interaction-level event.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": {
        "@value": "LPF",
        "@language": "de"
      },
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-general-phenomenology"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0010.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0198.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0093.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0119.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0010",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Cross-Era Cohort",
        "@language": "en"
      },
      "skos:notation": "AUG-0010",
      "skos:definition": {
        "@value": "A label for the cohort of people whose working lives span both the pre-AI and post-AI periods, giving them firsthand comparative experience of both. A descriptive population category, not a measurable interaction phenomenon.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": [
        {
          "@value": "Bridge Species",
          "@language": "en"
        },
        {
          "@value": "BRS",
          "@language": "de"
        }
      ],
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-general-phenomenology"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0119.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0198.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0093.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0010.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0198",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "The New Literacy",
        "@language": "en"
      },
      "skos:notation": "AUG-0198",
      "skos:definition": {
        "@value": "A societal tendency for competence in using AI tools to consolidate into a broadly expected cultural skill, comparable to earlier shifts in expected literacy. Denotes a gradual rise in baseline expected AI competence, not a single interaction.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": {
        "@value": "NLI",
        "@language": "de"
      },
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-general-phenomenology"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0119.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0010.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0093.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0198.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0093",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Zero-Marginal Cost",
        "@language": "en"
      },
      "skos:notation": "AUG-0093",
      "skos:definition": {
        "@value": "The tendency for the incremental cost of producing one additional unit of creative or informational output to fall toward negligible levels when AI assistance is used. Expressed as cost per additional produced unit, observed at the level of a task or workflow.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": {
        "@value": "ZMC",
        "@language": "de"
      },
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-general-phenomenology"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0119.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0010.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0198.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0093.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0099",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Adoption Window",
        "@language": "en"
      },
      "skos:notation": "AUG-0099",
      "skos:definition": {
        "@value": "A bounded early period in the uptake of an AI technology during which usage patterns form and their downstream effects are documented. Denotes a time interval of early adoption observed at population or organizational level, not a single interaction.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": {
        "@value": "AEI",
        "@language": "de"
      },
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-general-phenomenology"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0119.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0010.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0198.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0099.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0730",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "The Open-Source Path",
        "@language": "en"
      },
      "skos:notation": "AUG-0730",
      "skos:definition": {
        "@value": "A tendency toward the increasing availability of openly released AI models and the documented effects of that openness on who can access and build on such models. A macro trend in the model ecosystem, not an interaction-level phenomenon.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": {
        "@value": "OSP",
        "@language": "de"
      },
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-general-phenomenology"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0119.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0010.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0198.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0730.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0834",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Public Sentiment Oscillation",
        "@language": "en"
      },
      "skos:notation": "AUG-0834",
      "skos:definition": {
        "@value": "An oscillation over time in aggregate public sentiment toward AI, cycling between phases of enthusiasm and phases of caution. Denotes a longitudinal swing in measured population sentiment, observed at the level of discourse, not individual interaction.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": [
        {
          "@value": "Perception Wave",
          "@language": "en"
        },
        {
          "@value": "MPW",
          "@language": "de"
        }
      ],
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-general-phenomenology"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0119.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0010.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0198.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0834.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0808",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Knowledge Access Pattern",
        "@language": "en"
      },
      "skos:notation": "AUG-0808",
      "skos:definition": {
        "@value": "A descriptive label for the different routes by which groups and regions reach AI-mediated knowledge, characterizing pathways of access rather than enumerating barriers. A superordinate descriptive category spanning many specific access routes.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": {
        "@value": "KAP",
        "@language": "de"
      },
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-general-phenomenology"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0119.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0010.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0198.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0808.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0847",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Digital Native Dialogue",
        "@language": "en"
      },
      "skos:notation": "AUG-0847",
      "skos:definition": {
        "@value": "An exchange about AI spanning generational lines, in which younger habitual technology users and members of earlier generations share perspectives, characterized by reciprocal information transfer rather than one-directional instruction. The unit is a cross-generational conversational exchange.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": {
        "@value": "DND",
        "@language": "de"
      },
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-general-phenomenology"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0119.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0010.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0198.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0847.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0071",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "AI-Output Verification Practice",
        "@language": "en"
      },
      "skos:notation": "AUG-0071",
      "skos:definition": {
        "@value": "The degree to which a user applies systematic checking practices to AI-generated information, such as source-checking, cross-referencing across independent sources, and contextual appraisal before relying on it. A graded behavioral disposition in handling AI output.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": [
        {
          "@value": "Epistemic Hygiene",
          "@language": "en"
        },
        {
          "@value": "EPH",
          "@language": "de"
        }
      ],
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-general-phenomenology"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0075.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0076.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0024.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0071.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0075",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Knowledge-Base Curation Routine",
        "@language": "en"
      },
      "skos:notation": "AUG-0075",
      "skos:definition": {
        "@value": "A maintenance routine in which a user periodically reviews, sorts, updates, and prunes an accumulated AI-assisted knowledge base to keep it current and accurate. The construct is the regularity and completeness of this curation behavior.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": [
        {
          "@value": "The Gardener Protocol",
          "@language": "en"
        },
        {
          "@value": "GDP",
          "@language": "de"
        }
      ],
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-general-phenomenology"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0071.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0076.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0024.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0075.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0076",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Self-Referential Grounding",
        "@language": "en"
      },
      "skos:notation": "AUG-0076",
      "skos:definition": {
        "@value": "The extent to which a user anchors decisions during AI interaction in their own explicit value system, using personal criteria as the reference point when appraising or accepting AI output. A graded reliance on internally held standards.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": {
        "@value": "SRG",
        "@language": "de"
      },
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-general-phenomenology"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0071.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0075.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0024.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0076.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0024",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Internal Judgment Anchor",
        "@language": "en"
      },
      "skos:notation": "AUG-0024",
      "skos:definition": {
        "@value": "A user's internal orientation, formed from personal values, experience, and intuition, that they report drawing on to judge and correct AI output. The construct is the user's reliance on this internal reference, not any faculty of the AI system.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": [
        {
          "@value": "Built-In Compass",
          "@language": "en"
        },
        {
          "@value": "BIC",
          "@language": "de"
        }
      ],
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-general-phenomenology"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0071.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0075.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0076.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0024.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0011",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Reflective Operator",
        "@language": "en"
      },
      "skos:notation": "AUG-0011",
      "skos:definition": {
        "@value": "A user profile characterized by observable reflection on one's own AI use and deliberate refinement of that use over time, such as reviewing past interactions and adjusting strategies. The construct is the degree of metacognitive, self-revising engagement with one's AI practice.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": {
        "@value": "RFO",
        "@language": "de"
      },
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-general-phenomenology"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0071.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0075.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0076.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0011.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0078",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Naming Power",
        "@language": "en"
      },
      "skos:notation": "AUG-0078",
      "skos:definition": {
        "@value": "The general proposition that assigning a name to a phenomenon can alter how that phenomenon is subsequently perceived and discussed. A superordinate conceptual claim about language and perception, not a per-interaction occurrence.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": {
        "@value": "NMP",
        "@language": "de"
      },
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-general-phenomenology"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0071.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0075.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0076.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0078.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0001",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Augmanitai",
        "@language": "en"
      },
      "skos:notation": "AUG-0001",
      "skos:definition": {
        "@value": "A superordinate framework term for the deliberate, productive collaboration between humans and AI in everyday contexts, viewed from the human side. It blends 'augmentation' with a coined 'humanitai' root and, unlike 'artificial intelligence', foregrounds the human's experience and agency rather than the machine.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": {
        "@value": "AUG",
        "@language": "de"
      },
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-general-phenomenology"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0071.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0075.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0076.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0001.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0023",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Vigilance Imperative",
        "@language": "en"
      },
      "skos:notation": "AUG-0023",
      "skos:definition": {
        "@value": "A verification act in which a human user independently checks an AI-generated output against an external reference or domain knowledge before relying on it, distinguished from passive acceptance by the presence of an observable confirmation or correction step.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": {
        "@value": "VIG",
        "@language": "de"
      },
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-general-phenomenology"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0071.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0075.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0076.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0023.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0102",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Decision Authority Retention",
        "@language": "en"
      },
      "skos:notation": "AUG-0102",
      "skos:definition": {
        "@value": "A configuration of a human-AI workflow in which final decision authority is retained by the human rather than transferred to the AI system, characterised by the human's capacity to set, confirm, or override any AI-proposed action across delegated tasks.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": [
        {
          "@value": "Sovereignty Principle",
          "@language": "en"
        },
        {
          "@value": "SOV",
          "@language": "de"
        }
      ],
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-general-phenomenology"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0071.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0075.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0076.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0102.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0145",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Responsibility Gradient",
        "@language": "en"
      },
      "skos:notation": "AUG-0145",
      "skos:definition": {
        "@value": "A proposed monotonic relationship in which the share of accountability assigned to the human increases with the extent of authority delegated to the AI, treated as a relationship between delegated scope and assigned responsibility rather than as a single event.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": {
        "@value": "RES",
        "@language": "de"
      },
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-general-phenomenology"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0071.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0075.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0076.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0145.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0859",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Agent Handshake",
        "@language": "en"
      },
      "skos:notation": "AUG-0859",
      "skos:definition": {
        "@value": "The initial exchange that opens an interaction between a human and an autonomous agent, in which the agent's stated capabilities, permissions, and limits are surfaced; distinguished from later turns by being the first establishment of the working terms.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": {
        "@value": "AHS",
        "@language": "de"
      },
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-agentic-ai"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0860.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0914.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0888.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0859.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0860",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Delegation Depth",
        "@language": "en"
      },
      "skos:notation": "AUG-0860",
      "skos:definition": {
        "@value": "The breadth of decision latitude granted to an autonomous agent, ranging from narrow execution of pre-specified steps to discretionary action within broad goals; a graded property of a delegation arrangement rather than a discrete occurrence.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": {
        "@value": "DLD",
        "@language": "de"
      },
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-agentic-ai"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0859.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0914.html"
        },
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0888.html"
        }
      ],
      "rdfs:seeAlso": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0860.html"
      }
    },
    {
      "@id": "https://augmanitai.com/terms/AUG-0914",
      "@type": "skos:Concept",
      "skos:prefLabel": {
        "@value": "Physical Presence",
        "@language": "en"
      },
      "skos:notation": "AUG-0914",
      "skos:definition": {
        "@value": "A condition in which an AI system has a physical, embodied form present in the user's environment, treated as a graded contextual property of the interaction setting rather than as a discrete event or an effect claim.",
        "@language": "en"
      },
      "skos:inScheme": "https://augmanitai.com/terms/periodic/",
      "skos:altLabel": {
        "@value": "PHP",
        "@language": "de"
      },
      "skos:broader": {
        "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/#topic-agentic-ai"
      },
      "skos:related": [
        {
          "@id": "https://andreasehstandlicenseofclarityloc.github.io/augmanitai-periodic/terms/AUG-0859.html"
        },
        {
